#!/bin/sh
# pre-commit — chặn commit chứa secret bằng gitleaks.
# Bypass khẩn cấp: git commit --no-verify  (chỉ khi chắc chắn KHÔNG có secret)

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks chưa được cài — bỏ qua quét secret cho commit này."
  echo "    Cài bằng: brew install gitleaks"
  exit 0
fi

gitleaks protect --staged --redact -v
status=$?

if [ "$status" -ne 0 ]; then
  echo ""
  echo "❌ gitleaks phát hiện secret trong staged changes — commit bị CHẶN."
  echo "   • Gỡ secret khỏi diff rồi commit lại, HOẶC"
  echo "   • Nếu chắc chắn là false positive: git commit --no-verify"
  exit 1
fi

exit 0
