#!/bin/sh
# pre-commit — block commits containing secrets, using gitleaks.
# Emergency bypass: git commit --no-verify  (only when you are certain there is no secret)

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⚠️  gitleaks is not installed — skipping the secret scan for this commit."
  echo "    Install it with: brew install gitleaks"
  exit 0
fi

gitleaks protect --staged --redact -v
status=$?

if [ "$status" -ne 0 ]; then
  echo ""
  echo "❌ gitleaks found a secret in the staged changes — commit BLOCKED."
  echo "   • Remove the secret from the diff and commit again, OR"
  echo "   • If you are sure it is a false positive: git commit --no-verify"
  exit 1
fi

exit 0
