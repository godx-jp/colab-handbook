#!/usr/bin/env node
'use strict';
/*
 * colab — issue claims, port allocation and optional worktrees for parallel sessions/agents.
 * Plain Node, zero npm dependencies. Shells out to git/gh. State is machine-local at ~/.colab/.
 *
 * See tools/README.md for the full picture. `colab --help` and `colab <cmd> --help` are authoritative.
 */

const fs = require('fs');
const os = require('os');
const path = require('path');
const { spawnSync } = require('child_process');

const state = require('./lib/state');
const git = require('./lib/git');
const ports = require('./lib/ports');
const stamp = require('./lib/stamp');
const squash = require('./lib/squash');
const procs = require('./lib/procs');
const landed = require('./lib/landed');
const {
  HOST, UserError, normIssueNum, issueTag, claimKey, today, nowISO, hoursSince,
  parseArgs, table, shortRepo,
} = require('./lib/util');

// ---------------------------------------------------------------------------
// shared resolution helpers
// ---------------------------------------------------------------------------

/**
 * Absolute MAIN repo root from --repo or cwd; throws UserError if none.
 *
 * Always the main working tree, never a linked worktree — claims, ports and worktree records are
 * keyed by the main repo path, so resolving to a worktree makes every one of those lookups miss.
 * Running a command from inside the worktree it operates on is the obvious thing to do, and it
 * used to silently produce `(none claimed)`. This normalises both entry points, so `--repo <a
 * worktree path>` is corrected too.
 */
function resolveRepo(opts) {
  let r = opts.repo;
  if (r) {
    r = path.resolve(r);
    if (!fs.existsSync(r)) throw new UserError(`--repo path does not exist: ${opts.repo}`);
    const root = git.mainRepoRoot(r);
    return root || r; // allow a non-git path (local-only claims still work)
  }
  const root = git.mainRepoRoot(process.cwd());
  if (!root) throw new UserError('Not inside a git repo — pass --repo <path>');
  return root;
}

/** All repo roots colab should aggregate reserved ports from: config + current repo (if any). */
function knownRepos(config) {
  const cur = git.mainRepoRoot(process.cwd());
  const extra = cur ? [cur] : [];
  // include repos referenced by state worktrees too
  const st = state.loadState();
  for (const wt of Object.values(st.worktrees)) if (wt.repo) extra.push(wt.repo);
  return extra;
}

/** Find a single claim by issue number, optionally constrained to a repo. */
function findClaim(st, num, repoAbs) {
  const matches = Object.entries(st.claims).filter(([, c]) => normIssueNum(c.issue) === num);
  const scoped = repoAbs ? matches.filter(([k]) => k.startsWith(`${repoAbs}#`)) : matches;
  if (scoped.length === 0) return null;
  if (scoped.length > 1) {
    const repos = scoped.map(([k]) => shortRepo(k.split('#')[0])).join(', ');
    throw new UserError(`Issue #${num} is claimed in multiple repos (${repos}) — disambiguate with --repo`);
  }
  return { key: scoped[0][0], claim: scoped[0][1] };
}

function isGhUsable(repoAbs) {
  return git.ghAvailable() && !!git.originUrl(repoAbs);
}

// ---------------------------------------------------------------------------
// claim ENFORCEMENT — refusal, claim comments, and the tie-break for the
// simultaneous-claim race. See tools/README.md "Claim lifecycle" for the model.
//
// Claims are ENFORCED, not advisory: a claim held by another worktree (locally) or by
// another GitHub user (remotely) blocks a second claim unless --force takes it over
// visibly. The claim comment (feature 2) is both an audit trail on the Issue AND the
// substrate the tie-break (feature 3) parses to settle a true simultaneous race, since
// GitHub offers no atomic check-and-set on labels/assignees.
// ---------------------------------------------------------------------------

// The claim/release comment markers. These strings are a STABLE WIRE FORMAT: the refusal
// path, the tie-break, and future dashboards grep them. Do not reword casually.
const CLAIM_MARK = '🔒 Claimed';
const RELEASE_MARK = '✅ Released';
// Parses a claim comment body back into {worktree, branch, host, date}. The `· <host>` field
// is what lets the tie-break tell two machines of the SAME GitHub user apart. The optional
// trailing `· session <value>` (added 2026-07) is captured separately by SESSION_RE so this
// regex — and every existing parser — stays byte-stable for session-less comments.
const CLAIM_RE = /🔒 Claimed — worktree `([^`]*)` · branch `([^`]*)` · host `([^`]*)` · (\S+)/;
// The `· session <field>` tail, captured as the rest of the line. parseSessionField() then decodes
// the THREE shapes it can take — `[name](url)`, a bare URL, or a bare name — plus the legacy
// plain-URL form written before sessionName existed.
const SESSION_RE = /· session (.+)$/;

/**
 * Resolve the Claude session URL for this invocation: --session flag > COLAB_SESSION env >
 * '' (absent, never an error). Free-form — typically a session URL.
 */
function resolveSession(opts) {
  const s = opts.session || process.env.COLAB_SESSION || '';
  return String(s).trim();
}

/**
 * Resolve the short human session LABEL: --session-name flag > COLAB_SESSION_NAME env > ''.
 * A friendly name (e.g. `colab-handbook`, `pilot-issue-30`) shown in tables instead of a URL tail.
 */
function resolveSessionName(opts) {
  const s = opts.sessionName || process.env.COLAB_SESSION_NAME || '';
  return String(s).trim();
}

/**
 * A `sessionName` with no `session` URL is a HALF-identity, and it is worse than no identity at
 * all: the row reads as owned, yet nothing can join it to a session. `sessionName` is display
 * text; `session` is the only join key a consumer has (worktree.session → its `session_…` tail →
 * the live session). Never match on the name to close the gap — a consumer tried and reverted
 * after a worktree sat beside a live session with a near-identical name and was NOT it.
 *
 * So: WARN at the CREATION paths (claim, worktree new) — the one moment the URL is cheap to
 * supply — and never fail, because some agents genuinely have no session URL.
 */
function warnHalfIdentity(session, sessionName, what, ref) {
  if (!sessionName || session) return;
  warn(`session name "${sessionName}" recorded with NO session URL — this ${what} will read as owned`);
  warn(`  but cannot be traced to a session. The name is display text; the URL is the join key.`);
  if (ref) warn(`  Repair once you have it:  colab worktree tag ${ref} --session <url>`);
}

/** Compact a session URL for display: the `session_…` tail, or the raw value, capped. */
function shortSession(s) {
  if (!s) return '';
  s = String(s);
  const m = s.match(/session_[\w-]+/);
  const v = m ? m[0] : s;
  return v.length > 18 ? v.slice(0, 17) + '…' : v;
}

/**
 * The friendly identity for tables / plain-text messages: prefer the human `sessionName`, fall back
 * to the compacted URL, else '' (callers render '-'). `--json` always carries both raw fields.
 */
function displayIdentity(sessionName, session) {
  if (sessionName) return sessionName;
  if (session) return shortSession(session);
  return '';
}

/**
 * Table cell for the SESSION column. `displayIdentity` alone renders a name-with-no-URL row
 * IDENTICALLY to a fully-identified one — which is the whole defect: the row *looks* owned and
 * joins to nothing. The `(!)` suffix (explained by identityLegend below) is the only place a
 * reader can see the difference without opening state.json. `--json` is untouched: it always
 * carries both raw fields.
 */
function identityCell(sessionName, session) {
  const text = displayIdentity(sessionName, session) || '-';
  return (sessionName && !session) ? `${text} (!)` : text;
}

/** Print the `(!)` legend under a table, only when at least one row carries a half-identity. */
function identityLegend(entries) {
  if (!entries.some((e) => e && e.sessionName && !e.session)) return;
  print('  (!) session NAME with no session URL — reads as owned, links to nothing.');
  print('      Repair:  colab worktree tag <worktree> --session <url>');
}

/** The ` · session …` comment suffix, or '' — keeps the no-identity comment byte-stable. */
function sessionCommentSuffix(session, sessionName) {
  if (sessionName && session) return ` · session [${sessionName}](${session})`; // both → markdown link
  if (session) return ` · session ${session}`;                                  // url only → legacy form
  if (sessionName) return ` · session ${sessionName}`;                          // name only
  return '';
}

/**
 * Decode the `· session <field>` tail of a claim comment into { sessionName, session }. Accepts:
 *   `[name](url)`  → both;  bare `https://…`/`session_…` → url only;  any other bare token → name.
 * The bare-URL branch is exactly the LEGACY format written before sessionName existed, so old
 * comments keep parsing. Returns empty strings when there is no session tail.
 */
function parseSessionField(body) {
  const m = String(body).match(SESSION_RE);
  if (!m) return { sessionName: '', session: '' };
  const v = m[1].trim();
  const link = v.match(/^\[([^\]]*)\]\((.*)\)$/);
  if (link) return { sessionName: link[1], session: link[2] };
  if (/^https?:\/\//.test(v) || /session_[\w-]+/.test(v)) return { sessionName: '', session: v };
  return { sessionName: v, session: '' };
}

/**
 * Worktree lifecycle status, backfilled-on-read: entries created before this field existed (or by
 * an older colab) render as `running`. Values: `running` (default, at create) → `merged` (branch
 * landed on trunk + no live claims; set by ship after B1, or auto-detected by doctor). "Killed" is
 * not a status — teardown removes the entry entirely.
 */
function wtStatus(wt) { return (wt && wt.status) || 'running'; }

/** The exact claim-comment body. Keep in lockstep with CLAIM_RE/parseSessionField and the README. */
function claimCommentBody(wtName, branch, session, sessionName) {
  const base = `${CLAIM_MARK} — worktree \`${wtName || '-'}\` · branch \`${branch}\` · host \`${HOST}\` · ${nowISO()}`;
  return base + sessionCommentSuffix(session, sessionName); // no-identity body stays EXACTLY as before
}

/** Issues whose EXISTING local claim sits on a different worktree than the one we're claiming onto. */
function localClaimConflicts(st, repoAbs, nums, wtName) {
  const want = wtName || null;
  const out = [];
  for (const num of nums) {
    const ex = st.claims[claimKey(repoAbs, num)];
    if (!ex) continue;
    if ((ex.worktree || null) === want) continue; // idempotent — same holder
    // UPGRADE, not a collision: a TRUNK claim (worktree null) held on THIS host is the
    // same session moving its work into a worktree. Refusing it made `colab claim N`
    // followed by `colab worktree new --issues N` — the documented session order —
    // reject the user's own claim. Note the GitHub check below already excludes
    // yourself (`!assignees.includes(myLogin)`); this keeps the local side from being
    // asymmetrically stricter than the remote one.
    // Still a conflict: a DIFFERENT worktree holds it (two sessions on one machine),
    // or the trunk claim belongs to another host.
    if (want !== null && (ex.worktree || null) === null && ex.host === HOST) continue;
    out.push({ num, holder: ex });
  }
  return out;
}

/**
 * Issues GitHub shows as claimed by SOMEONE ELSE: label `in-progress` present AND a non-empty
 * assignee set that does not include us. A read failure (null) is skipped, never treated as free.
 */
function ghClaimConflicts(repoAbs, nums, myLogin) {
  const out = [];
  for (const num of nums) {
    const info = git.ghIssueView(repoAbs, num, ['assignees', 'labels']);
    if (!info) continue; // couldn't read → don't block on a failed read
    const labeled = (info.labels || []).some((l) => l.name === 'in-progress');
    const assignees = (info.assignees || []).map((a) => a.login);
    if (labeled && assignees.length > 0 && !assignees.includes(myLogin)) out.push({ num, assignees });
  }
  return out;
}

/** Print the two-layer refusal and the escape hatches. */
function printRefusal(localConf, ghConf) {
  process.stderr.write('✗ Refusing — one or more issues are already claimed:\n');
  for (const c of localConf) {
    const h = c.holder;
    const id = displayIdentity(h.sessionName, h.session);
    const sess = id ? ` · session ${id}` : '';
    process.stderr.write(
      `  #${c.num} local: worktree "${h.worktree || '-'}" · branch ${h.branch || '-'} · host ${h.host}${sess} · since ${String(h.created).slice(0, 10)}\n`);
  }
  for (const c of ghConf) {
    process.stderr.write(`  #${c.num} GitHub: assigned to ${c.assignees.join(', ')} (labeled in-progress)\n`);
  }
  process.stderr.write('  Re-run with --force to take over, or claim a different issue.\n');
  process.stderr.write('  Stale claims from dead worktrees are freed by: colab doctor --prune\n');
}

/** Announce exactly what --force overrides (a takeover is visible, never silent). */
function printTakeover(localConf, ghConf) {
  for (const c of localConf) {
    const h = c.holder;
    const id = displayIdentity(h.sessionName, h.session);
    const sess = id ? `, session ${id}` : '';
    print(`  --force: taking over #${c.num} from worktree "${h.worktree || '-'}" (host ${h.host}${sess}, since ${String(h.created).slice(0, 10)})`);
  }
  for (const c of ghConf) {
    print(`  --force: taking over #${c.num} from GitHub assignee ${c.assignees.join(', ')}`);
  }
}

/**
 * Live claim comments on an issue = every `🔒 Claimed` not cancelled by a LATER `✅ Released`
 * from the SAME GitHub author. Returns [{login, host, at, identity}], `at` = the comment's real
 * GitHub createdAt (authoritative, sub-second), `identity` = `login@host`.
 */
function liveClaimComments(comments) {
  const sorted = [...comments].sort((a, b) => (a.createdAt < b.createdAt ? -1 : a.createdAt > b.createdAt ? 1 : 0));
  // releases per author login (release comments carry no host — cancellation is by author, per spec)
  const releasesByLogin = new Map();
  for (const c of sorted) {
    if (String(c.body || '').trim().startsWith(RELEASE_MARK)) {
      const login = (c.author && c.author.login) || '';
      if (!releasesByLogin.has(login)) releasesByLogin.set(login, []);
      releasesByLogin.get(login).push(c.createdAt);
    }
  }
  const live = [];
  for (const c of sorted) {
    const body = String(c.body || '').trim();
    const m = body.match(CLAIM_RE);
    if (!m) continue;
    const login = (c.author && c.author.login) || '';
    const host = m[3];
    const { session, sessionName } = parseSessionField(body); // handles [name](url) / url / name / legacy
    const at = c.createdAt;
    const cancelled = (releasesByLogin.get(login) || []).some((r) => r > at);
    if (!cancelled) live.push({ login, host, session, sessionName, at, identity: `${login}@${host}` });
  }
  return live;
}

/**
 * Deterministic verdict on the simultaneous-claim race. Given the issue's comments, our login and
 * host: if a live claim from a DIFFERENT author-or-host is EARLIER than ours → we lost (returns the
 * winner). Exact-timestamp ties break on identity string (lexicographically smaller identity wins),
 * so both racers, reading the same comments, reach the same verdict independently.
 */
function tieBreakVerdict(comments, myLogin, myHost) {
  const live = liveClaimComments(comments);
  const mine = live
    .filter((c) => c.login === myLogin && c.host === myHost)
    .sort((a, b) => (a.at > b.at ? -1 : a.at < b.at ? 1 : 0))[0]; // our latest live claim
  if (!mine) return { lost: false }; // our own comment not visible yet → don't yield to a phantom
  let winner = null;
  for (const c of live) {
    if (c.login === myLogin && c.host === myHost) continue; // never yield to ourselves
    const earlier = c.at < mine.at || (c.at === mine.at && c.identity < mine.identity);
    if (!earlier) continue;
    if (!winner || c.at < winner.at || (c.at === winner.at && c.identity < winner.identity)) winner = c;
  }
  return winner ? { lost: true, winner } : { lost: false };
}

/** Post the claim comment (best-effort: a failure warns but never fails the claim). */
function postClaimComment(repoAbs, num, wtName, branch, session, sessionName) {
  const r = git.ghIssueComment(repoAbs, num, claimCommentBody(wtName, branch, session, sessionName));
  if (!r.ok) warn(`could not post claim comment on #${num} (${r.stderr.split('\n')[0] || r.code}) — claim stands`);
}

/**
 * Post `✅ Released` on an issue, UNLESS it is already CLOSED (a `Closes #N` merge already ended the
 * story). Best-effort. Used by release + worktree rm.
 */
function postReleaseComment(repoAbs, num) {
  const info = git.ghIssueView(repoAbs, num, ['state']);
  if (info && info.state === 'CLOSED') return; // don't chatter on a closed issue
  const r = git.ghIssueComment(repoAbs, num, RELEASE_MARK);
  if (!r.ok) warn(`could not post release comment on #${num} (${r.stderr.split('\n')[0] || r.code})`);
}

/**
 * We lost the race for #num → yield it. Removes our local claim, posts the yield notice, and
 * (only when the winner is a DIFFERENT GitHub user) removes our label + @me assignee. When the
 * winner shares our login (another machine of ours), the GitHub label/assignee is a single shared
 * marker the winner still needs — so we leave it and let the comment layer record the handover.
 */
function yieldIssue(repoAbs, num, winner, myLogin) {
  if (winner.login !== myLogin) {
    const r = git.ghIssueEdit(repoAbs, num, ['--remove-label', 'in-progress', '--remove-assignee', '@me']);
    if (!r.ok) warn(`gh: could not remove our label/assignee on #${num} while yielding (${r.stderr.split('\n')[0] || r.code})`);
  }
  const rc = git.ghIssueComment(repoAbs, num, `${RELEASE_MARK} (yielded — earlier claim by ${winner.identity} wins)`);
  if (!rc.ok) warn(`could not post yield comment on #${num} (${rc.stderr.split('\n')[0] || rc.code})`);
  state.mutate((st) => { delete st.claims[claimKey(repoAbs, num)]; });
}

/**
 * Run the claim comment + tie-break for issues we just claimed on GitHub. Returns the list of
 * issue numbers we LOST (already yielded). `owner` is {wtName, branch, myLogin, session, sessionName}.
 */
function commentAndTieBreak(repoAbs, nums, owner) {
  const lost = [];
  for (const num of nums) {
    postClaimComment(repoAbs, num, owner.wtName, owner.branch, owner.session, owner.sessionName);
    const info = git.ghIssueView(repoAbs, num, ['comments']);
    if (!info || !Array.isArray(info.comments)) continue; // can't read comments → keep the claim
    const verdict = tieBreakVerdict(info.comments, owner.myLogin, HOST);
    if (verdict.lost) {
      yieldIssue(repoAbs, num, verdict.winner, owner.myLogin);
      const w = verdict.winner;
      const id = displayIdentity(w.sessionName, w.session);
      const wsess = id ? ` · session ${id}` : '';
      warn(`Yielded #${num} — an earlier simultaneous claim by ${w.identity}${wsess} wins. Pick another issue.`);
      lost.push(num);
    }
  }
  return lost;
}

// ---------------------------------------------------------------------------
// claim / release / claims
// ---------------------------------------------------------------------------

const HELP_CLAIM = `colab claim <issue> [<issue> ...] [options]

Claim one or more GitHub issues so parallel sessions/agents don't collide.
Writes BOTH local state (fast path) and GitHub (source of truth across machines):
  gh issue edit N --add-assignee @me --add-label in-progress
If gh is unavailable or the repo has no remote, degrades to local-only (and says so).

Multiple issues in one call are claimed atomically onto the SAME worktree/branch
(a group of related issues on one branch is normal practice):
  colab claim 115 114 113 --worktree import-fixes-115-114-113 --branch fix/import-fixes-115-114-113

Claims are ENFORCED, not advisory. Before claiming, colab REFUSES (exit 1) if:
  • LOCAL:  the issue already has a live claim on a DIFFERENT worktree (holder shown), or
  • GITHUB: the issue is labeled in-progress AND assigned to someone who isn't you.
Re-claiming onto the SAME worktree is idempotent (OK). --force takes over either layer,
printing exactly what it overrides. On a successful claim colab posts a "🔒 Claimed" comment
on the Issue; if a simultaneous racer claimed microseconds earlier, the tie-break yields to
them automatically (see tools/README.md "Claim lifecycle").

Options:
  --repo <path>       repo root (default: git root of cwd)
  --worktree <name>   attach these claims to a worktree entity (ports live on the worktree)
  --branch <name>     branch these claims are worked on (informational; default: trunk)
  --session <url>     Claude session URL recorded on the claim + comment (default: COLAB_SESSION env)
  --session-name <s>  short human label shown in tables/messages (default: COLAB_SESSION_NAME env)
  --force             take over a claim held by another worktree / GitHub user (logged, never silent)
`;

function cmdClaim(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo', '--worktree': 'worktree', '--branch': 'branch', '--session': 'session', '--session-name': 'sessionName' },
    flags: { '--force': 'force', '-h': 'help', '--help': 'help' },
  });
  if (opts.help || opts._.length === 0) return print(HELP_CLAIM);
  const repoAbs = resolveRepo(opts);
  const nums = opts._.map(normIssueNum);
  const branch = opts.branch || 'trunk';
  const wtName = opts.worktree || null;
  const session = resolveSession(opts);
  const sessionName = resolveSessionName(opts);
  warnHalfIdentity(session, sessionName, 'claim', wtName);
  const gh = isGhUsable(repoAbs);
  const myLogin = gh ? git.ghCurrentLogin() : null;

  // ---- REFUSAL (two layers, check-then-refuse) ----
  const localConf = localClaimConflicts(state.loadState(), repoAbs, nums, wtName);
  const ghConf = gh ? ghClaimConflicts(repoAbs, nums, myLogin) : [];
  if (!gh) warn('gh not usable here (no gh auth or no origin remote) — refusal is LOCAL-ONLY');
  if ((localConf.length || ghConf.length)) {
    if (!opts.force) { printRefusal(localConf, ghConf); return 1; }
    printTakeover(localConf, ghConf);
  }

  // ---- claim locally (idempotent on same worktree; --force overwrites a different holder) ----
  const res = state.mutate((st) => {
    if (wtName && !st.worktrees[wtName]) {
      // allow claiming onto a worktree name that will be created later (informational link)
      st.worktrees[wtName] = { name: wtName, repo: repoAbs, branch, path: null, ports: [], host: HOST, session, sessionName, status: 'running', created: nowISO() };
    }
    const created = [], reclaimed = [];
    for (const num of nums) {
      const key = claimKey(repoAbs, num);
      const ex = st.claims[key];
      if (ex && (ex.worktree || null) === (wtName || null)) { reclaimed.push(num); continue; } // idempotent
      st.claims[key] = { issue: issueTag(num), repo: repoAbs, worktree: wtName, branch, host: HOST, session, sessionName, created: nowISO() };
      created.push(num);
    }
    return { created, reclaimed };
  });

  for (const num of res.reclaimed) print(`#${num} already claimed by this worktree — OK (idempotent)`);

  // ---- GitHub side (outside the lock — network): assign/label, comment, tie-break ----
  let lost = [];
  if (gh) {
    for (const num of res.created) {
      const r = git.ghIssueEdit(repoAbs, num, ['--add-assignee', '@me', '--add-label', 'in-progress']);
      if (r.ok) print(`  gh: #${num} assigned + labeled in-progress`);
      else warn(`gh edit #${num} failed (${r.stderr.split('\n')[0] || r.code}) — local claim stands`);
    }
    lost = commentAndTieBreak(repoAbs, res.created, { wtName, branch, myLogin, session, sessionName });
  } else {
    warn('gh not usable here — claims are LOCAL-ONLY (no comment, no tie-break)');
  }

  const kept = res.created.filter((n) => !lost.includes(n));
  if (kept.length) {
    print(`Claimed ${kept.map((n) => '#' + n).join(' ')} in ${shortRepo(repoAbs)}` +
      (wtName ? ` → worktree "${wtName}" (branch ${branch})` : ` (trunk)`));
  }
  // Lost any issue to the tie-break → non-zero so the caller picks another.
  return lost.length ? 1 : 0;
}

const HELP_RELEASE = `colab release <issue> [--repo <path>]

Release a single issue: removes the local claim and, if gh is usable, runs
  gh issue edit N --remove-assignee @me --remove-label in-progress
Sibling claims on the same worktree stay alive (a group finishes issues one at a time).
The worktree is NEVER auto-removed here (uncommitted work may exist); if this was the
last claim, the output says the worktree now has zero claims.
`;

function cmdRelease(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo' }, flags: { '-h': 'help', '--help': 'help' },
  });
  if (opts.help || opts._.length === 0) return print(HELP_RELEASE);
  const num = normIssueNum(opts._[0]);
  const repoAbs = opts.repo ? resolveRepo(opts) : (git.repoRoot(process.cwd()) || null);

  let found;
  const out = state.mutate((st) => {
    found = findClaim(st, num, repoAbs);
    if (!found) return null;
    delete st.claims[found.key];
    const wtName = found.claim.worktree;
    let remaining = null;
    if (wtName) {
      remaining = Object.values(st.claims).filter((c) => c.worktree === wtName).length;
    }
    return { repo: found.claim.repo, wtName, remaining };
  });

  if (!out) throw new UserError(`No local claim for #${num}` + (repoAbs ? ` in ${shortRepo(repoAbs)}` : ''));

  if (isGhUsable(out.repo)) {
    const r = git.ghIssueEdit(out.repo, num, ['--remove-assignee', '@me', '--remove-label', 'in-progress']);
    if (r.ok) print(`  gh: #${num} unassigned + label removed`);
    else warn(`gh edit #${num} failed (${r.stderr.split('\n')[0] || r.code}) — local claim already removed`);
    postReleaseComment(out.repo, num); // "✅ Released" unless the issue is already CLOSED
  } else {
    warn('gh not usable here — released LOCAL-ONLY');
  }
  print(`Released #${num} from ${shortRepo(out.repo)}`);
  if (out.wtName && out.remaining === 0) {
    print(`  note: worktree "${out.wtName}" now has ZERO claims (not removed — run: colab worktree rm ${out.wtName})`);
  } else if (out.wtName) {
    print(`  worktree "${out.wtName}" still has ${out.remaining} claim(s)`);
  }
  return 0;
}

const HELP_CLAIMS = `colab claims [--json] [--sync]

List all local claims, grouped by worktree.
  --json    machine-readable output
  --sync    reconcile local state against GitHub (per repo). ADD-ONLY by default: issues
            assigned to you AND labeled in-progress on GitHub but missing locally are added.
            Local claims are NEVER removed unless you also pass --prune.
  --prune   (with --sync) also REMOVE local claims for issues GitHub no longer shows as
            assigned+in-progress, printing exactly what is removed and why.

Removal is opt-in because a successful-but-partial GitHub response (rate limit, paging)
is indistinguishable from a complete one, so a destructive reconcile must be deliberate.
Repos gh can't reach are skipped entirely (never treated as "no claims").
`;

function cmdClaims(argv) {
  const opts = parseArgs(argv, { flags: { '--json': 'json', '--sync': 'sync', '--prune': 'prune', '-h': 'help', '--help': 'help' } });
  if (opts.help) return print(HELP_CLAIMS);
  if (opts.prune && !opts.sync) throw new UserError('--prune only applies together with --sync');
  if (opts.sync) syncClaims({ prune: !!opts.prune });

  const st = state.loadState();
  if (opts.json) { print(JSON.stringify(st.claims, null, 2)); return 0; }

  const claims = Object.values(st.claims);
  if (claims.length === 0) { print('No active claims.'); return 0; }

  // group by worktree (null → "(trunk / no worktree)")
  const groups = new Map();
  for (const c of claims) {
    const g = c.worktree || '(trunk / no worktree)';
    if (!groups.has(g)) groups.set(g, []);
    groups.get(g).push(c);
  }
  for (const [g, cs] of groups) {
    const wt = st.worktrees[g];
    const portStr = wt && wt.ports.length ? ` ports:${wt.ports.join(',')}` : '';
    print(`\n▸ ${g}${portStr}`);
    const rows = cs.map((c) => [c.issue, shortRepo(c.repo), c.branch || '-', c.host, identityCell(c.sessionName, c.session), c.created.slice(0, 10)]);
    print(table(rows, ['ISSUE', 'REPO', 'BRANCH', 'HOST', 'SESSION', 'SINCE']).split('\n').map((l) => '  ' + l).join('\n'));
    identityLegend(cs);
  }
  return 0;
}

function syncClaims({ prune = false } = {}) {
  if (!git.ghAvailable()) { warn('gh not available — --sync skipped'); return; }
  const st = state.loadState();
  // repos represented locally + repos with an origin
  const repos = new Set(Object.values(st.claims).map((c) => c.repo));
  const cur = git.repoRoot(process.cwd());
  if (cur) repos.add(cur);

  const added = [], removed = [];
  for (const repoAbs of repos) {
    if (!git.originUrl(repoAbs)) continue;
    const assigned = git.ghAssignedIssues(repoAbs);
    // A repo gh can't reach is SKIPPED — never treated as "GitHub shows no claims"
    // (that guard is exactly why removal must be opt-in: a partial/failed read must not delete).
    if (assigned === null) { warn(`gh could not list issues for ${shortRepo(repoAbs)} — skipped`); continue; }
    const assignedSet = new Set(assigned);
    // GH → local: ADD missing (always)
    for (const num of assignedSet) {
      const key = claimKey(repoAbs, num);
      state.mutate((s) => {
        if (!s.claims[key]) {
          s.claims[key] = { issue: issueTag(num), repo: repoAbs, worktree: null, branch: 'trunk', host: HOST, created: nowISO() };
          added.push(`+#${num} ${shortRepo(repoAbs)} (assigned+in-progress on GitHub, missing locally)`);
        }
      });
    }
    // local → GH: REMOVE stale local claims ONLY when --prune is given
    if (prune) {
      const localForRepo = Object.entries(st.claims).filter(([k]) => k.startsWith(`${repoAbs}#`));
      for (const [key, c] of localForRepo) {
        const num = normIssueNum(c.issue);
        if (!assignedSet.has(num)) {
          state.mutate((s) => {
            if (s.claims[key]) { delete s.claims[key]; removed.push(`-#${num} ${shortRepo(repoAbs)} (no longer assigned+in-progress on GitHub)`); }
          });
        }
      }
    }
  }

  if (added.length) { print('Sync — added from GitHub:'); added.forEach((c) => print('  ' + c)); }
  if (prune) {
    if (removed.length) { print('Sync — pruned local claims:'); removed.forEach((c) => print('  ' + c)); }
    else if (!added.length) print('Sync: nothing to add or prune — already in agreement with GitHub.');
  } else {
    if (!added.length) print('Sync: nothing to add (add-only; pass --prune to also remove stale local claims).');
    else print('  (add-only — pass --prune to also remove local claims GitHub no longer shows)');
  }
}

