function worktreeSubdir(config) { return config.worktreeSubdir || '.worktrees'; }

function runHook(repoAbs, name, ctx) {
  const hook = path.join(repoAbs, '.colab', 'hooks', name);
  try {
    const st = fs.statSync(hook);
    if (!st.isFile()) return { ran: false };
    // executable?
    if (!(st.mode & 0o111)) { warn(`hook ${name} exists but is not executable — skipped`); return { ran: false }; }
  } catch (_) { return { ran: false }; }
  const env = {
    ...process.env,
    COLAB_WORKTREE_PATH: ctx.wtPath, COLAB_WORKTREE_NAME: ctx.name, COLAB_BRANCH: ctx.branch,
    COLAB_PORTS: (ctx.ports || []).join(','), COLAB_REPO: repoAbs, COLAB_TRUNK: ctx.trunk || '',
    // The branch this session was cut from and ships back into — trunk unless the repo declared an
    // integration line and the session asked for it. Hooks that clone a DB or seed an environment
    // need the base, not the trunk, or they set the session up against the wrong schema.
    COLAB_BASE: ctx.base || ctx.trunk || '',
    COLAB_ISSUES: (ctx.issues || []).join(','),
  };
  print(`  running hook ${name} …`);
  const r = spawnSync(hook, [ctx.wtPath, ...(ctx.ports || []).map(String)], { stdio: 'inherit', env });
  return { ran: true, ok: r.status === 0, code: r.status };
}

function cmdWorktreeNew(argv) {
  const opts = parseArgs(argv, {
    values: { '--issues': 'issues', '--ports': 'ports', '--range': 'range', '--at': 'at', '--name': 'name', '--trunk': 'trunk', '--base': 'base', '--repo': 'repo', '--session': 'session', '--session-name': 'sessionName' },
    aliases: { '--issue': '--issues' },
    flags: { '--force': 'force', '-h': 'help', '--help': 'help' },
  });
  if (opts.help || opts._.length === 0) return print(HELP_WORKTREE);
  if (opts.at && (opts.ports || opts.range)) throw new UserError('--at pins exact ports — it cannot be combined with --ports / --range');
  const config = state.loadConfig();
  const repoAbs = resolveRepo(opts);
  if (!git.repoRoot(repoAbs)) throw new UserError(`${repoAbs} is not a git repo`);

  const branch = opts._[0];
  const name = opts.name || (branch.includes('/') ? branch.slice(branch.indexOf('/') + 1) : branch);
  const issues = opts.issues ? String(opts.issues).split(',').map(normIssueNum) : [];
  const portCount = opts.ports ? parseInt(opts.ports, 10) : 0;
  const atPorts = parseAtPorts(opts);
  const range = resolveWorktreeRange(opts, config, repoAbs); // --range > repo worktreePorts > default
  const session = resolveSession(opts);
  const sessionName = resolveSessionName(opts);
  warnHalfIdentity(session, sessionName, 'worktree (and its claims)', name);
  const gh = isGhUsable(repoAbs);
  const myLogin = gh ? git.ghCurrentLogin() : null;

  // ---- REFUSAL: don't build a worktree around issues someone else already holds ----
  if (issues.length) {
    const localConf = localClaimConflicts(state.loadState(), repoAbs, issues, name);
    const ghConf = gh ? ghClaimConflicts(repoAbs, issues, myLogin) : [];
    if (!gh) warn('gh not usable here — issue refusal is LOCAL-ONLY');
    if (localConf.length || ghConf.length) {
      if (!opts.force) { printRefusal(localConf, ghConf); return 1; }
      printTakeover(localConf, ghConf);
    }
  }

  // trunk: project.yml → origin/HEAD
  let trunk = opts.trunk;
  if (!trunk) {
    const pj = path.join(repoAbs, '.github', 'project.yml');
    try {
      const doc = require('./lib/yaml').parse(fs.readFileSync(pj, 'utf8'));
      if (doc && doc.trunk) trunk = String(doc.trunk);
    } catch (_) { /* fall through */ }
  }
  if (!trunk) trunk = git.detectTrunk(repoAbs);
  if (!trunk) throw new UserError('Could not determine trunk branch — pass --trunk <name>');

  // ---- base: trunk by default, a DECLARED integration line by request ----
  // Only branches the repo has declared may be a base. "Some other branch" stays improvisation, and
  // improvisation is what put a main checkout on a long-lived line in the first place.
  const doc = projectDoc(repoAbs);
  const bases = allowedBases(repoAbs, doc, trunk);
  const base = opts.base ? String(opts.base).trim() : trunk;
  if (base !== trunk && !bases.includes(base)) {
    throw new UserError(
      `--base "${base}" is not a declared base for this repo. Allowed: ${bases.join(', ')}.\n` +
      '  Add it to .github/project.yml `integration:` if it is a long-lived line the team keeps ' +
      '(project.schema.md), rather than branching off it ad hoc.');
  }

  const wtPath = path.join(repoAbs, worktreeSubdir(config), name);
  if (fs.existsSync(wtPath)) throw new UserError(`Worktree path already exists: ${wtPath}`);

  // 1. fetch + create worktree
  print(`fetch origin/${base} + create worktree "${name}" (branch ${branch})`);
  const fetch = git.git(['fetch', 'origin', base], repoAbs);
  if (!fetch.ok) warn(`git fetch failed (${fetch.stderr.split('\n')[0]}) — creating from local origin/${base}`);
  const add = git.git(['worktree', 'add', wtPath, '-b', branch, `origin/${base}`], repoAbs);
  if (!add.ok) throw new UserError(`git worktree add failed: ${add.stderr}`);
  const baseSha = git.git(['rev-parse', '--short', `origin/${base}`], repoAbs).stdout;

  // How far behind trunk the line is, as INFORMATION — never a threshold. A long-lived line is
  // expected to diverge; a refusal (or a warning with a number in it) would fire on every healthy
  // session and be tuned out within a week.
  if (base !== trunk) {
    const behind = git.git(['rev-list', '--count', `origin/${base}..origin/${trunk}`], repoAbs);
    print(`  base is the declared line "${base}"` +
      (behind.ok ? `, ${behind.stdout} commit(s) behind ${trunk} (expected for a long-lived line)` : ''));
    print(`  this worktree ships back into ${base}; merging ${base} → ${trunk} stays a human act.`);
  }

  // 2. copy env files (never committed)
  const envCopied = [];
  for (const f of ['.env', '.env.local']) {
    const src = path.join(repoAbs, f);
    if (fs.existsSync(src)) { fs.copyFileSync(src, path.join(wtPath, f)); envCopied.push(f); }
  }

  // 3. allocate ports + record worktree + claims (atomic)
  const alloc = state.mutate((st) => {
    let chosenPorts = [];
    if (atPorts) {
      const reserved = ports.reservedSet(config, [repoAbs, ...knownRepos(config)]);
      const conflicts = ports.checkExact(atPorts, st, reserved);
      if (conflicts.length) {
        throw new UserError(`Cannot pin ${conflicts.map((c) => `${c.port} (${c.reason})`).join(', ')} — pick free ports`);
      }
      chosenPorts = atPorts;
    } else if (portCount > 0) {
      const reserved = ports.reservedSet(config, [repoAbs, ...knownRepos(config)]);
      const found = ports.findConsecutive(portCount, range, st, reserved);
      if (!found) throw new UserError(`Could not find ${portCount} consecutive free ports in ${range}`);
      chosenPorts = found;
    }
    // `base` is recorded even when it IS trunk: a reader must be able to tell "cut from trunk" from
    // "cut before bases existed", and only a written value says the first.
    st.worktrees[name] = { name, repo: repoAbs, branch, base, path: wtPath, ports: chosenPorts, host: HOST, session, sessionName, status: 'running', created: nowISO() };
    for (const p of chosenPorts) st.ports[String(p)] = { port: p, owner: { type: 'worktree', ref: name }, host: HOST, created: nowISO() };
    const claimedNums = [], dupes = [];
    for (const num of issues) {
      const key = claimKey(repoAbs, num);
      // claim inherits the worktree's session
      if (st.claims[key]) { dupes.push(num); st.claims[key].worktree = name; st.claims[key].branch = branch; st.claims[key].session = session; st.claims[key].sessionName = sessionName; continue; }
      st.claims[key] = { issue: issueTag(num), repo: repoAbs, worktree: name, branch, host: HOST, session, sessionName, created: nowISO() };
      claimedNums.push(num);
    }
    return { chosenPorts, claimedNums, dupes };
  });

  // 4. GitHub claim (network, outside lock): assign/label, then comment + tie-break
  let lostIssues = [];
  if (gh) {
    const claimedHere = [...alloc.claimedNums, ...alloc.dupes];
    for (const num of claimedHere) {
      const r = git.ghIssueEdit(repoAbs, num, ['--add-assignee', '@me', '--add-label', 'in-progress']);
      if (!r.ok) warn(`gh edit #${num} failed — local claim stands`);
    }
    lostIssues = commentAndTieBreak(repoAbs, claimedHere, { wtName: name, branch, myLogin, session, sessionName });
    if (lostIssues.length) {
      warn(`Worktree "${name}" was created, but issue(s) ${lostIssues.map((n) => '#' + n).join(' ')} were lost to a`);
      warn(`simultaneous claim and yielded. The worktree remains — reuse it for another issue, or:`);
      warn(`  colab worktree rm ${name}`);
    }
  } else if (issues.length) {
    warn('gh not usable — issue claims are LOCAL-ONLY (no comment, no tie-break)');
  }

  // 5. optional repo hook (machine-specific steps plug in here)
  const hook = runHook(repoAbs, 'post-create', { wtPath, name, branch, ports: alloc.chosenPorts, trunk, base, issues });
  if (hook.ran && !hook.ok) warn(`post-create hook exited ${hook.code} — worktree was still created; finish setup manually`);

  print('');
  print(`✓ Worktree ready`);
  print(`  path:     ${wtPath}`);
  print(`  branch:   ${branch}  (base origin/${base} @ ${baseSha})${base === trunk ? '' : '  [declared line]'}`);
  print(`  env:      ${envCopied.join(' ') || '—'}`);
  print(`  ports:    ${alloc.chosenPorts.join(', ') || '—'}`);
  const keptIssues = issues.filter((n) => !lostIssues.includes(n));
  print(`  issues:   ${keptIssues.map((n) => '#' + n).join(' ') || '—'}${gh ? '' : ' (local-only)'}` +
    (lostIssues.length ? `  (lost: ${lostIssues.map((n) => '#' + n).join(' ')})` : ''));
  return lostIssues.length ? 1 : 0;
}

function cmdWorktreeRm(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo' }, flags: { '--force': 'force', '-h': 'help', '--help': 'help' },
  });
  if (opts.help || opts._.length === 0) return print(HELP_WORKTREE);
  const name = opts._[0];
  const st0 = state.loadState();
  const wt = st0.worktrees[name];
  if (!wt) throw new UserError(`No worktree "${name}" in state`);
  const repoAbs = wt.repo;

  // safety: refuse if tracked changes uncommitted
  if (wt.path && fs.existsSync(wt.path)) {
    const dirty = git.dirtyTracked(wt.path);
    if (dirty && !opts.force) {
      warn(dirty);
      throw new UserError(`Worktree "${name}" has uncommitted TRACKED changes — commit/stash, or pass --force`);
    }
  }

  // safety: refuse if the worktree still OWNS running processes (cwd inside it).
  // Same shape as the uncommitted-work gate above, and deliberately in the CLI rather than in the
  // skills: code-wrap B4 and code-sweep §3 both tear worktrees down on separate code paths, so a
  // skill-level fix would have to be written twice into two files already drifting apart.
  const owned = wt.path && fs.existsSync(wt.path) ? procs.processesInDir(wt.path) : [];
  if (owned.length && !opts.force) {
    warn(`Worktree "${name}" still owns ${owned.length} running process(es):`);
    for (const p of owned) {
      warn(`  pid ${p.pid}${p.ports.length ? '  port ' + p.ports.join(',') : '  (no listener)'}  ${p.command}`);
    }
    throw new UserError(
      'Removing the worktree would orphan them — they keep serving from a deleted checkout, ' +
      'and the freed ports would be a lie. Stop them, or pass --force to terminate them.');
  }
  const killed = [];
  for (const p of owned) {
    const gone = procs.terminate(p.pid);
    killed.push({ ...p, gone });
    if (!gone) warn(`pid ${p.pid} survived SIGKILL — port ${p.ports.join(',') || '?'} may stay bound`);
  }

  const attachedIssues = Object.values(st0.claims).filter((c) => c.worktree === name).map((c) => normIssueNum(c.issue));

  // pre-remove hook (abort on failure unless --force)
  const hook = runHook(repoAbs, 'pre-remove', { wtPath: wt.path, name, branch: wt.branch, ports: wt.ports, issues: attachedIssues });
  if (hook.ran && !hook.ok && !opts.force) throw new UserError(`pre-remove hook exited ${hook.code} — aborting (use --force to override)`);

  // git worktree remove
  if (wt.path && fs.existsSync(wt.path)) {
    // always --force at the git level: copied .env / hook artifacts are untracked-but-expected;
    // the tracked-changes safety gate above is what actually protects unsaved work.
    const r = git.git(['worktree', 'remove', '--force', wt.path], repoAbs);
    if (!r.ok) warn(`git worktree remove reported: ${r.stderr.split('\n')[0]}`);
  }

  // GitHub: release each attached issue (unassign + delabel + "✅ Released" unless already CLOSED)
  const gh = isGhUsable(repoAbs);
  for (const num of attachedIssues) {
    if (gh) {
      git.ghIssueEdit(repoAbs, num, ['--remove-assignee', '@me', '--remove-label', 'in-progress']);
      postReleaseComment(repoAbs, num);
    }
  }

  // state: drop claims, ports, worktree
  const removed = state.mutate((st) => {
    const claims = Object.keys(st.claims).filter((k) => st.claims[k].worktree === name);
    for (const k of claims) delete st.claims[k];
    const freedPorts = Object.keys(st.ports).filter((p) => st.ports[p].owner.type === 'worktree' && st.ports[p].owner.ref === name);
    for (const p of freedPorts) delete st.ports[p];
    delete st.worktrees[name];
    return { claims: claims.length, freedPorts };
  });

  print(`✓ Removed worktree "${name}"`);
  print(`  released ${removed.claims} claim(s)${attachedIssues.length ? ' (' + attachedIssues.map((n) => '#' + n).join(' ') + ')' : ''}${gh ? '' : ' (local-only)'}`);
  if (killed.length) print(`  stopped ${killed.filter((k) => k.gone).length}/${killed.length} owned process(es): ${killed.map((k) => k.pid).join(', ')}`);

  // "freed" must mean freed. Reporting a port as free while something still answers on it is what
  // turned a leaked process into a clean bill of health, and it poisons the registry in both
  // directions: the next session is handed the port and hits EADDRINUSE, or slides silently to
  // another one. Verify each port, and name the ones that are still bound.
  const stillBound = removed.freedPorts.filter((p) => procs.portIsBound(Number(p)));
  const trulyFreed = removed.freedPorts.filter((p) => !stillBound.includes(p));
  print(`  freed ports: ${trulyFreed.join(', ') || '—'}`);
  if (stillBound.length) {
    warn(`ports still BOUND after teardown: ${stillBound.join(', ')} — released in the registry but something is listening.`);
    warn(`  find it with: lsof -iTCP:${stillBound[0]} -sTCP:LISTEN -P`);
  }
  return 0;
}

/**
 * `colab worktree tag <name> --session <url> [--session-name <s>]` — repair session identity on an
 * ALREADY-created worktree. Before this, the only fix was hand-editing ~/.colab/state.json.
 *
 * It writes BOTH records. Claims keep their own copies of `session`/`sessionName` (inherited at
 * creation), and claims are what `colab doctor` reports on — so a worktree-only repair would leave
 * doctor still printing anonymous rows and look like the fix had not worked. One command, both.
 */
function cmdWorktreeTag(argv) {
  const opts = parseArgs(argv, {
    values: { '--session': 'session', '--session-name': 'sessionName' },
    flags: { '-h': 'help', '--help': 'help' },
  });
  if (opts.help || opts._.length === 0) return print(HELP_WORKTREE);
  const name = opts._[0];
  // Deliberately NOT resolveSession()/resolveSessionName(): the env fallback belongs to CREATION.
  // A repair must write exactly what the operator passed — inheriting COLAB_SESSION_NAME from a
  // shell that never had COLAB_SESSION is how the half-identity is produced in the first place.
  const session = String(opts.session || '').trim();
  const sessionName = String(opts.sessionName || '').trim();
  if (!session && !sessionName) {
    throw new UserError('Nothing to tag — pass --session <url> and/or --session-name <s>');
  }
  if (!state.loadState().worktrees[name]) {
    throw new UserError(`No worktree "${name}" in state (list them with: colab worktrees)`);
  }

  const out = state.mutate((st) => {
    const wt = st.worktrees[name];
    if (!wt) throw new UserError(`No worktree "${name}" in state`); // lost the race with a rm
    const before = { session: wt.session || '', sessionName: wt.sessionName || '' };
    if (session) wt.session = session;
    if (sessionName) wt.sessionName = sessionName;
    const claims = [];
    for (const c of Object.values(st.claims)) {
      if (c.worktree !== name) continue;
      if (session) c.session = session;
      if (sessionName) c.sessionName = sessionName;
      claims.push(c.issue);
    }
    return { before, after: { session: wt.session || '', sessionName: wt.sessionName || '' }, claims };
  });

  const arrow = (b, a) => `${b || '—'} → ${a || '—'}`;
  print(`✓ Tagged worktree "${name}"`);
  print(`  session:      ${arrow(out.before.session, out.after.session)}`);
  print(`  sessionName:  ${arrow(out.before.sessionName, out.after.sessionName)}`);
  print(`  claims retagged: ${out.claims.join(' ') || '— (none attached)'}`);
  // Already-posted "🔒 Claimed" comments are NOT rewritten: a comment is a dated record of what was
  // known then, and editing history to look tidy is exactly the lie this handbook warns about.
  print(`  note: existing GitHub claim comments keep their original text (history, not state)`);
  warnHalfIdentity(out.after.session, out.after.sessionName, 'worktree', name);
  return 0;
}

function cmdWorktree(argv) {
  const sub = argv[0];
  if (sub === 'new') return cmdWorktreeNew(argv.slice(1));
  if (sub === 'rm') return cmdWorktreeRm(argv.slice(1));
  if (sub === 'tag') return cmdWorktreeTag(argv.slice(1));
  return print(HELP_WORKTREE);
}

function cmdWorktrees(argv) {
  const opts = parseArgs(argv, { flags: { '--json': 'json', '-h': 'help', '--help': 'help' } });
  if (opts.help) return print(HELP_WORKTREE);
  const st = state.loadState();
  if (opts.json) { print(JSON.stringify(st.worktrees, null, 2)); return 0; }
  const wts = Object.values(st.worktrees);
  if (wts.length === 0) { print('No worktrees.'); return 0; }
  const rows = wts.map((wt) => {
    const claims = Object.values(st.claims).filter((c) => c.worktree === wt.name).map((c) => c.issue).join(' ') || '-';
    const alive = wt.path ? (fs.existsSync(wt.path) ? 'yes' : 'MISSING') : 'n/a';
    // A non-trunk base is shown inline rather than in its own column: it is rare, and a worktree
    // that ships somewhere other than trunk must not look identical to one that does. Read from
    // project.yml directly — resolveTrunk's origin/HEAD fallback can hit the network, and listing
    // worktrees must stay a local, instant command.
    const doc = projectDoc(wt.repo);
    const declaredTrunk = doc && doc.trunk ? String(doc.trunk) : '';
    const branchCell = wt.base && declaredTrunk && wt.base !== declaredTrunk ? `${wt.branch} → ${wt.base}` : wt.branch;
    return [wt.name, shortRepo(wt.repo), branchCell, wt.ports.join(',') || '-', claims, wtStatus(wt), identityCell(wt.sessionName, wt.session), alive];
  });
  print(table(rows, ['NAME', 'REPO', 'BRANCH', 'PORTS', 'ISSUES', 'STATUS', 'SESSION', 'ON-DISK']));
  identityLegend(wts);
  return 0;
}

// ---------------------------------------------------------------------------
// doctor
// ---------------------------------------------------------------------------

const HELP_DOCTOR = `colab doctor [--prune] [--ttl <hours>] [--json]

Health-check the machine-local state and heal drift.
  - A worktree whose directory no longer exists on disk is DEAD: its claims are pruned
    and its ports freed (--prune actually removes; default only reports).
  - Claims referencing a worktree that isn't in state are orphans (same treatment).
  - Worktree-less claims older than TTL (default 24h, --ttl to change) are REPORTED, not
    auto-removed (they may be deliberate trunk claims). --prune removes them too and frees
    any ports they own.
  - Ports owned by a vanished worktree/claim are freed on --prune.
  - A \`running\` worktree whose branch has landed on trunk (tree-contained, incl. squash merges) AND
    holds NO live claims is flipped to \`merged\` (recorded on --prune). ANY live claim keeps it
    running (an unfinished group sibling). \`merged\` worktrees still on disk are sweep candidates;
    --prune tears them down fully (pre-remove hook, git worktree remove, free ports) — but refuses
    ones with uncommitted TRACKED changes, reporting them instead. \`running\` worktrees are NEVER
    swept.
  - Branches whose content is already in trunk are listed as ROUTINE MAINTENANCE, after the health
    verdict and never counted as drift: \`ship\` keeps the branch by default, so one accumulates per
    shipped session by design. doctor never deletes a ref — not even with --prune — it prints the
    commands. \`git branch --merged\` cannot find these (a squash leaves no ancestry), so nothing
    else will. Branches checked out in a worktree are excluded (a live session's branch is not
    spent), and so are branches that CONFLICT against trunk rather than matching it — the list is
    honest rather than exhaustive.

This exists because claims made without a worktree were never auto-healed before, and a
real repo accumulated 17 stale same-day claims. Run \`colab doctor\` regularly; \`--prune\`
in a cleanup cron.

  --prune   apply the fixes (default: report only)
  --ttl N   hours before a worktree-less claim is flagged stale (default 24)
  --json    machine-readable report
`;

const EMPTY_SET = new Set();

/**
 * Local branches whose content is already in trunk — the routine cleanup list.
 *
 * This is the PRIMARY mechanism, not a backstop. `ship` keeps the branch by default (deleting refs
 * from a shared remote is not an agent's call), so a shipped branch accumulates per session by
 * design and this list is expected to be non-empty. `git branch --merged <trunk>` cannot find any
 * of them: sessions squash-merge, which leaves the branch tip outside trunk's ancestry, so the
 * standard cleanup check reports clean forever. We reuse branchContainedInTrunk (a merge-tree
 * content test) which is correct across squashes, and skip anything checked out in a worktree — a
 * live session's branch is not spent, and an empty branch freshly cut from trunk is "contained" by
 * construction.
 *
 * KNOWN HOLE, stated because a cleanup list that quietly under-reports is worse than none: a branch
 * whose work trunk has since REWRITTEN conflicts against trunk rather than matching it, so
 * branchContainedInTrunk answers "not contained" and it never appears here. That is the safe
 * direction to be wrong in — the alternative is telling someone unmerged work is spent — but it
 * means this list is honest, not exhaustive, and a periodic human sweep is still warranted. We hit
 * exactly this case cleaning up after issue #17.
 *
 * REPORT ONLY, even under --prune. doctor's other prunes touch only colab's own state file;
 * deleting refs across every repo a shared machine happens to know about is categorically different.
 */
function shippedBranches(repos, st) {
  const out = [];
  // repo -> its live session branches. A NESTED map, not a composite string key: a flat key needs
  // a separator, and the only separator that cannot collide with a path or a ref name is NUL --
  // which, typed raw, silently turned this file into 'binary data' (grep found nothing without
  // -a, while node --check and git diff stayed happy). Nesting needs no separator at all, so the
  // whole class of bug is gone rather than escaped around.
  const liveByRepo = new Map();
  for (const w of Object.values(st.worktrees)) {
    if (!liveByRepo.has(w.repo)) liveByRepo.set(w.repo, new Set());
    liveByRepo.get(w.repo).add(w.branch);
  }
  for (const repo of repos) {
    if (!repo || !fs.existsSync(repo) || !git.repoRoot(repo)) continue;
    const doc = projectDoc(repo);
    const trunk = resolveTrunk(repo, doc);
    if (!trunk) continue;
    // A declared integration line is never "spent": it is an integration point that outlives many
    // sessions, and it is contained in trunk by construction for as long as nothing has been merged
    // into it yet — which is exactly when suggesting its deletion would be most destructive.
    const lines = resolveIntegration(repo, doc, trunk);
    // Branches checked out anywhere in this repo (main checkout + every worktree) are off limits.
    const checkedOut = new Set(
      git.git(['worktree', 'list', '--porcelain'], repo).stdout.split('\n')
        .filter((l) => l.startsWith('branch '))
        .map((l) => l.slice('branch '.length).replace(/^refs\/heads\//, '')),
    );
    const refs = git.git(['for-each-ref', '--format=%(refname:short)', 'refs/heads/'], repo);
    if (!refs.ok) continue;
    for (const branch of refs.stdout.split('\n').filter(Boolean)) {
      if (branch === trunk || branch === 'main' || lines.includes(branch)) continue;
      if (checkedOut.has(branch)) continue;
      if ((liveByRepo.get(repo) || EMPTY_SET).has(branch)) continue;
      if (!branchContainedInTrunk(repo, branch).contained) continue;
      const onRemote = git.git(['rev-parse', '--verify', '--quiet', `refs/remotes/origin/${branch}`], repo).ok;
      out.push({ repo: shortRepo(repo), repoAbs: repo, branch, trunk, remote: onRemote });
    }
  }
  return out;
}

function cmdDoctor(argv) {
  const opts = parseArgs(argv, {
    values: { '--ttl': 'ttl' }, flags: { '--prune': 'prune', '--json': 'json', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_DOCTOR);
  const config = state.loadConfig();
  const ttl = opts.ttl ? parseFloat(opts.ttl) : config.claimTTLHours;

  const report = { deadWorktrees: [], orphanClaims: [], staleClaims: [], orphanPorts: [], prunedPorts: [],
    mergedFlips: [], mergedSweep: [], mergedDirty: [], mergedHookFail: [], shippedBranches: [], ghostPorts: [], pruned: !!opts.prune };

  const apply = (fn) => opts.prune ? state.mutate(fn) : fn(state.loadState());

  apply((st) => {
    // 1. dead worktrees (path gone)
    for (const wt of Object.values(st.worktrees)) {
      const dead = wt.path && !fs.existsSync(wt.path);
      if (!dead) continue;
      const claims = Object.entries(st.claims).filter(([, c]) => c.worktree === wt.name);
      report.deadWorktrees.push({ name: wt.name, repo: shortRepo(wt.repo), path: wt.path, ports: wt.ports, claims: claims.map(([, c]) => c.issue), session: wt.session || '', sessionName: wt.sessionName || '' });
      if (opts.prune) {
        for (const [k] of claims) delete st.claims[k];
        for (const p of wt.ports) { delete st.ports[String(p)]; report.prunedPorts.push(p); }
        delete st.worktrees[wt.name];
      }
    }
    // 2. orphan claims (worktree ref not in state)
    for (const [k, c] of Object.entries(st.claims)) {
      if (c.worktree && !st.worktrees[c.worktree]) {
        report.orphanClaims.push({ issue: c.issue, repo: shortRepo(c.repo), worktree: c.worktree });
        if (opts.prune) delete st.claims[k];
      }
    }
    // 3. stale worktree-less claims (report only; prune if asked)
    for (const [k, c] of Object.entries(st.claims)) {
      if (!c.worktree) {
        const age = hoursSince(c.created);
        if (age > ttl) {
          report.staleClaims.push({ issue: c.issue, repo: shortRepo(c.repo), ageHours: Math.round(age), host: c.host, session: c.session || '', sessionName: c.sessionName || '' });
          if (opts.prune) {
            // free any ports owned by this claim
            for (const p of Object.keys(st.ports)) {
              if (st.ports[p].owner.type === 'claim' && st.ports[p].owner.ref === k) { delete st.ports[p]; report.prunedPorts.push(Number(p)); }
            }
            delete st.claims[k];
          }
        }
      }
    }
    // 4. orphan ports (owner vanished)
    for (const [p, rec] of Object.entries(st.ports)) {
      const o = rec.owner;
      const orphan = (o.type === 'worktree' && !st.worktrees[o.ref]) || (o.type === 'claim' && !st.claims[o.ref]);
      if (orphan) {
        report.orphanPorts.push({ port: Number(p), owner: `${o.type}:${o.ref}` });
        if (opts.prune) { delete st.ports[p]; report.prunedPorts.push(Number(p)); }
      }
    }
    // 5. running worktrees whose branch has landed on trunk AND that hold no live claims → merged.
    //    ANY live claim (an unfinished group sibling) keeps it running, regardless of branch content.
    for (const wt of Object.values(st.worktrees)) {
      if (wtStatus(wt) !== 'running') continue;
      if (!wt.path || !fs.existsSync(wt.path)) continue; // dead handled in pass 1; stubs have no tree
      const liveClaims = Object.values(st.claims).filter((c) => c.worktree === wt.name).length;
      if (liveClaims > 0) continue;
      // Against the base this worktree was CUT FROM. A session on a declared integration line has
      // shipped when its content is on the line; measuring it against trunk would keep it "running"
      // for as long as the line lives.
      const res = branchContainedInTrunk(wt.repo, wt.branch, wt.base);
      if (res.contained) {
        report.mergedFlips.push({ name: wt.name, repo: shortRepo(wt.repo), branch: wt.branch });
        if (opts.prune) wt.status = 'merged';
      }
    }
  });

  // 6. merged worktrees still on disk = sweep candidates. Report always; --prune tears them down
  //    (pre-remove hook → git worktree remove → free ports → drop entry). Done OUTSIDE the pass-1..5
  //    lock to avoid nesting state.mutate; refuse ones with uncommitted TRACKED files (report instead).
  //    running worktrees are NEVER touched by this sweep.
  {
    const st2 = state.loadState();
    for (const wt of Object.values(st2.worktrees)) {
      if (wtStatus(wt) !== 'merged') continue;
      if (!wt.path || !fs.existsSync(wt.path)) continue;
      const dirty = git.dirtyTracked(wt.path);
      if (dirty) { report.mergedDirty.push({ name: wt.name, repo: shortRepo(wt.repo) }); continue; }
      report.mergedSweep.push({ name: wt.name, repo: shortRepo(wt.repo), ports: wt.ports });
      if (!opts.prune) continue;
      const attached = Object.values(st2.claims).filter((c) => c.worktree === wt.name).map((c) => normIssueNum(c.issue));
      const hook = runHook(wt.repo, 'pre-remove', { wtPath: wt.path, name: wt.name, branch: wt.branch, ports: wt.ports, issues: attached });
      if (hook.ran && !hook.ok) { report.mergedHookFail.push(wt.name); continue; } // pre-remove veto → leave it
      if (fs.existsSync(wt.path)) git.git(['worktree', 'remove', '--force', wt.path], wt.repo);
      // LOCAL-ONLY: doctor never touches GitHub (a cron may be pruning a shared machine). A flipped
      // merged worktree has no claims by the flip guard; a ship --keep-worktree residual claim is for
      // an already-shipped (Closes) issue, so we drop it locally and let claims --sync reconcile GitHub.
      state.mutate((st3) => {
        for (const k of Object.keys(st3.claims)) if (st3.claims[k].worktree === wt.name) delete st3.claims[k];
        for (const p of Object.keys(st3.ports)) {
          if (st3.ports[p].owner.type === 'worktree' && st3.ports[p].owner.ref === wt.name) { delete st3.ports[p]; report.prunedPorts.push(Number(p)); }
        }
        delete st3.worktrees[wt.name];
      });
    }
  }

  // 7. shipped-but-undeleted branches. Report-only in every mode (see shippedBranches).
  {
    const st4 = state.loadState();
    const repos = [...new Set([...(config.repos || []), ...knownRepos(config)].map((r) => path.resolve(r)))];
    report.shippedBranches = shippedBranches(repos, st4);
  }

  // 8. ghost ports: something is LISTENING on a port the registry considers free.
  //    Join two books and report the disagreement — never pick a winner, and never kill by port
  //    (only cwd proves ownership; see lib/procs.js). Scoped to the allocation window and minus
  //    the reserved trunk ports, which are SUPPOSED to be bound.
  {
    const st5 = state.loadState();
    const [lo, hi] = ports.parseRange(config.portRange || '5200-5999');
    const reserved = new Set(ports.reservedSet(config, knownRepos(config)).keys());
    const allocated = new Set(Object.keys(st5.ports).map(Number));
    const seen = new Set();
    for (const l of procs.listeners()) {
      if (!(l.port >= lo && l.port <= hi)) continue;
      if (allocated.has(l.port) || reserved.has(l.port) || seen.has(l.port)) continue;
      seen.add(l.port);
      const cwd = procs.cwdOf(l.pid);
      report.ghostPorts.push({ port: l.port, pid: l.pid, command: procs.commandOf(l.pid), cwd, cwdGone: !!cwd && !fs.existsSync(cwd) });
    }
  }

  if (opts.json) { print(JSON.stringify(report, null, 2)); return 0; }

  const verb = opts.prune ? 'Pruned' : 'Found';
  let issues = 0;
  if (report.deadWorktrees.length) {
    issues += report.deadWorktrees.length;
    print(`${verb} ${report.deadWorktrees.length} dead worktree(s) (directory gone):`);
    for (const w of report.deadWorktrees) print(`  ${w.name} [${w.repo}] claims=${w.claims.join(' ') || '-'} ports=${w.ports.join(',') || '-'}${displayIdentity(w.sessionName, w.session) ? ` session=${displayIdentity(w.sessionName, w.session)}` : ''}`);
  }
  if (report.orphanClaims.length) {
    issues += report.orphanClaims.length;
    print(`${verb} ${report.orphanClaims.length} orphan claim(s) (worktree not in state):`);
    for (const c of report.orphanClaims) print(`  ${c.issue} [${c.repo}] → missing worktree "${c.worktree}"`);
  }
  if (report.staleClaims.length) {
    print(`${opts.prune ? 'Pruned' : 'Flagged'} ${report.staleClaims.length} stale worktree-less claim(s) (> ${ttl}h):`);
    for (const c of report.staleClaims) print(`  ${c.issue} [${c.repo}] age=${c.ageHours}h host=${c.host}${displayIdentity(c.sessionName, c.session) ? ` session=${displayIdentity(c.sessionName, c.session)}` : ''}`);
    if (!opts.prune) print('  (worktree-less claims are not auto-removed — re-run with --prune to remove)');
  }
  if (report.orphanPorts.length) {
    print(`${verb} ${report.orphanPorts.length} orphan port(s):`);
    for (const p of report.orphanPorts) print(`  ${p.port} owner=${p.owner}`);
  }
  if (report.mergedFlips.length) {
    print(`${opts.prune ? 'Flipped' : 'Detected'} ${report.mergedFlips.length} worktree(s) running → merged (branch landed on trunk, no live claims):`);
    for (const w of report.mergedFlips) print(`  ${w.name} [${w.repo}] branch=${w.branch}`);
    if (!opts.prune) print('  (status recorded on --prune, which also sweeps merged worktrees)');
  }
  if (report.mergedSweep.length) {
    print(`${opts.prune ? 'Swept' : 'Sweep candidates —'} ${report.mergedSweep.length} merged worktree(s) on disk:`);
    for (const w of report.mergedSweep) print(`  ${w.name} [${w.repo}] ports=${w.ports.join(',') || '-'}`);
    if (!opts.prune) print('  (re-run with --prune to tear these down: hook + git worktree remove + free ports)');
  }
  if (report.mergedDirty.length) {
    print(`Skipped ${report.mergedDirty.length} merged worktree(s) with uncommitted TRACKED changes (not swept):`);
    for (const w of report.mergedDirty) print(`  ${w.name} [${w.repo}] — commit/stash, or remove with: colab worktree rm ${w.name} --force`);
  }
  if (report.mergedHookFail.length) {
    print(`Left ${report.mergedHookFail.length} merged worktree(s) — pre-remove hook vetoed teardown: ${report.mergedHookFail.join(' ')}`);
  }
  if (opts.prune && report.prunedPorts.length) print(`Freed ports: ${[...new Set(report.prunedPorts)].sort((a, b) => a - b).join(', ')}`);
  // Deliberately NOT part of the health verdict below. `ship` keeps branches by default, so one
  // accumulates per shipped session BY DESIGN — this is a routine maintenance list a human works
  // through when they feel like it, not drift, and not a sign anything went wrong.
  const nothing = issues === 0 && report.staleClaims.length === 0 && report.orphanPorts.length === 0 &&
    report.mergedFlips.length === 0 && report.mergedSweep.length === 0 && report.mergedDirty.length === 0;
  if (nothing) print('All healthy — nothing to prune.');

  // Printed AFTER the health verdict, on purpose: these are not drift. `ship` keeps the branch by
  // default, so this list grows by one per shipped session and is expected to be non-empty.
  if (report.shippedBranches.length) {
    print('');
    print(`Shipped branches you can delete when convenient (${report.shippedBranches.length}) — content is already in trunk:`);
    for (const b of report.shippedBranches) {
      print(`  ${b.branch} [${b.repo}] → in ${b.trunk}${b.remote ? ' · also on origin' : ''}`);
    }
    print('  Routine, not drift: `ship` keeps branches by default, so one lands here per session.');
    print('  Listed here because `git branch --merged` cannot see them — a squash leaves no ancestry.');
    print('  doctor never deletes a ref, --prune included. To remove one:');
    const ex = report.shippedBranches[0];
    print(`    git -C <repo> branch -D ${ex.branch}${ex.remote ? `  &&  git -C <repo> push origin --delete ${ex.branch}` : ''}`);
    print('  NOT exhaustive: a branch whose work trunk later rewrote can conflict against trunk');
    print('  instead of matching it, and is omitted here rather than risk calling unmerged work spent.');
  }
  if (report.ghostPorts.length) {
    issues += report.ghostPorts.length;
    print('');
    print(`Ghost ports (${report.ghostPorts.length}) — LISTENING, but the registry says free:`);
    for (const g of report.ghostPorts) {
      print(`  ${g.port}  pid ${g.pid}  ${g.command}`);
      if (g.cwd) print(`        cwd ${g.cwd}${g.cwdGone ? '   ← DELETED (orphan of a torn-down worktree)' : ''}`);
    }
    print('  The next allocation can hand one of these out, and the session then hits EADDRINUSE');
    print('  — or a non-strict dev server slides to another port and the registry is wrong twice.');
    print('  doctor never kills by port (only cwd proves ownership). Inspect, then stop it yourself:');
    print(`    lsof -iTCP:${report.ghostPorts[0].port} -sTCP:LISTEN -P   &&   kill ${report.ghostPorts[0].pid}`);
    print('  A LEGITIMATE long-running service in the window (an emulator, a database) is not drift —');
    print('  declare it so it stops reporting: add its port to `extraReserved` in ~/.colab/config.json,');
    print('  which also stops colab handing it to a worktree. A "cwd DELETED" line above is the real');
    print('  orphan and wants killing, not reserving.');
  }
  return 0;
}

// ---------------------------------------------------------------------------
// release-notes
//
// MIRRORS templates/release-tag.yml "Build grouped release summary" step. The two CANNOT
// share code — the workflow must stay copy-and-own self-contained (git+shell, no Node) — so
// they are deliberate duplicates. If you change the grouping/format here, make the matching
// edit in templates/release-tag.yml (and vice versa). Born from a real gap: when org GitHub
// Actions was billing-locked the workflow couldn't run, and the summary had to be built by
// hand locally. This subcommand makes that manual path first-class and non-drifting.
// ---------------------------------------------------------------------------

// Conventional Commit types, in display order. Keep in lockstep with the workflow's emit_group
// calls + its Other/Breaking grep alternation.
const CC_TYPES = ['feat', 'fix', 'perf', 'refactor', 'docs', 'chore', 'test'];

const HELP_RELEASE_NOTES = `colab release-notes [<range>] [--repo <path>] [--out <file>] [--headline "<text>"]

Build a grouped Markdown release summary from git history — the same grouping the release
workflow (templates/release-tag.yml) produces, but runnable locally (e.g. when CI is down).

  <range>       a git revision range, e.g. v0.3.0..v0.4.0
                Default: <most recent tag reachable from HEAD>..HEAD
                If the repo has no tags and no range is given, this errors (it will not guess).
  --repo <path> repo root (default: git root of cwd)
  --out <file>  write to a file instead of stdout
  --headline "<text>"   one sentence inserted right after the commit-count line (e.g. the
                        highlight of the release). Optional; nothing is hardcoded.

Output: an H2 "Release summary", a line stating N non-merge commits since <base>, the optional
headline, then "### <type> (<count>)" sections (feat, fix, perf, refactor, docs, chore, test)
with "- <subject>" bullets, plus an "### Other (<count>)" bucket for unprefixed subjects.

Composable — pipe straight into gh:
  colab release-notes v0.3.0..v0.4.0 | gh release create v0.4.0 --notes-file - --generate-notes
`;

/** Left-hand side of a git range as the "base" label, or null if the range isn't a two-dot range. */
function rangeBase(range) {
  const m = String(range).split(/\.\.\.?/); // handles both A..B and A...B
  if (m.length < 2) return null;            // single revision → whole history, no base
  return m[0] || null;                      // guard against "..HEAD"
}

function cmdReleaseNotes(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo', '--out': 'out', '--headline': 'headline' },
    flags: { '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_RELEASE_NOTES);
  const repoAbs = resolveRepo(opts);
  if (!git.repoRoot(repoAbs)) throw new UserError(`${repoAbs} is not a git repo`);

  // Resolve the range + its base label.
  let range = opts._[0];
  let base;
  if (range) {
    base = rangeBase(range);
  } else {
    // Default: since the most recent tag reachable from HEAD.
    const d = git.git(['describe', '--tags', '--abbrev=0'], repoAbs);
    if (!d.ok || !d.stdout) {
      throw new UserError('No tags in this repo — pass an explicit <range> (e.g. v0.1.0..HEAD). Refusing to guess.');
    }
    base = d.stdout;
    range = `${base}..HEAD`;
  }

  // Non-merge commit subjects in the range. A merge subject carries no Conventional Commit
  // meaning and would double-count its own commits, so --no-merges (same as the workflow).
  const log = git.git(['log', range, '--no-merges', '--format=%s'], repoAbs);
  if (!log.ok) {
    throw new UserError(`git log ${range} failed: ${log.stderr.split('\n')[0] || `exit ${log.code}`}`);
  }
  const subjects = log.stdout.split('\n').filter(Boolean);

  // Group by type. Match 'feat: x', 'feat(scope): x', and the breaking 'feat!: x' / 'feat(x)!: y'.
  const groups = Object.fromEntries(CC_TYPES.map((t) => [t, []]));
  const other = [];
  const re = new RegExp(`^(${CC_TYPES.join('|')})(\\([^)]*\\))?!?:`);
  for (const s of subjects) {
    const m = s.match(re);
    if (m) groups[m[1]].push(s); else other.push(s);
  }

  // Build Markdown.
  let out = `## Release summary\n\n`;
  out += base
    ? `${subjects.length} commits since \`${base}\`.\n`
    : `${subjects.length} commits.\n`;
  if (opts.headline) out += `\n${opts.headline}\n`;
  out += `\n`;
  for (const t of CC_TYPES) {
    if (!groups[t].length) continue;
    out += `### ${t} (${groups[t].length})\n`;
    out += groups[t].map((s) => `- ${s}`).join('\n') + '\n\n';
  }
  if (other.length) {
    out += `### Other (${other.length})\n`;
    out += other.map((s) => `- ${s}`).join('\n') + '\n\n';
  }

  if (opts.out) {
    fs.writeFileSync(opts.out, out.endsWith('\n') ? out : out + '\n');
    process.stderr.write(`Wrote ${subjects.length} commits (${range}) → ${opts.out}\n`);
  } else {
    process.stdout.write(out);
  }
  return 0;
}

// ---------------------------------------------------------------------------
// register — keep the TWO machine-local registries in sync in one act
//
// The fleet lives in two files that used to be hand-edited separately (the two-places-drift
// disease this handbook fights):
//   1. <COLAB_HOME>/repos.txt      the audit fleet list (audit.mjs reads it; COLAB_HOME-aware)
//   2. <COLAB_HOME>/config.json    repos[] — the reserved-ports aggregation source (this CLI)
// `colab register` writes BOTH, dedups, and `--list` flags any drift between them.
// ---------------------------------------------------------------------------

const REPOS_TXT_HEADER =
`# Fleet registry — MACHINE-LOCAL, not committed. Read by audit.mjs and colab.
# One entry per line: an absolute repo path, or an owner/name slug. '#' starts a comment.
# Managed by \`colab register\` (which keeps this file and config.json repos[] in sync).
`;

function reposTxtPath() { return path.join(state.COLAB_DIR, 'repos.txt'); }

function readReposTxt() {
  try { return fs.readFileSync(reposTxtPath(), 'utf8'); }
  catch (e) { if (e.code === 'ENOENT') return null; throw e; }
}

/** Stripped, non-empty entry values from repos.txt content. */
function reposTxtEntries(text) {
  if (!text) return [];
  return text.split(/\r?\n/).map((l) => l.replace(/#.*$/, '').trim()).filter(Boolean);
}

/** An owner/name slug (audit-only) rather than a local path — can't be a port-scan root. */
function isSlug(x) { return !x.startsWith('/') && !x.startsWith('~') && /^[^/]+\/[^/]+$/.test(x); }

const HELP_REGISTER = `colab register [<path>] [--remove] [--list]

Register a repo into BOTH machine-local registries at once, so they never drift:
  • <COLAB_HOME>/repos.txt   — the audit fleet list (audit.mjs)
  • <COLAB_HOME>/config.json  — repos[], the reserved-ports aggregation source (this CLI)

  <path>      repo to register (default: the git root of the current directory). Must be a
              git repo — non-git paths are refused. The path is normalized to its toplevel.
  --remove    remove the repo from BOTH registries.
  --list      show every registered repo and which registry knows it (T = repos.txt,
              C = config.json). A local path present in only one registry is DRIFT and is
              flagged; slugs are audit-only (repos.txt) and never counted as drift.
              Exits non-zero if any drift is found (scriptable), 0 otherwise.

Idempotent: registering an already-registered repo reports it and exits 0.
`;

function cmdRegister(argv) {
  const opts = parseArgs(argv, {
    flags: { '--remove': 'remove', '--list': 'list', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_REGISTER);
  if (opts.list) return registerList();

  // Resolve target: explicit path arg, else the current repo root. Refuse non-git.
  let target = opts._[0] ? path.resolve(opts._[0]) : git.repoRoot(process.cwd());
  if (!target) throw new UserError('Not inside a git repo — pass a <path> to register');
  const root = git.repoRoot(target);
  if (!root) throw new UserError(`Not a git repo: ${target} — register only tracks git repos`);
  target = root; // normalize to the worktree toplevel

  return opts.remove ? registerRemove(target) : registerAdd(target);
}

function registerAdd(target) {
  // One lock guards both files so the two registries update together.
  const res = state.withLock(() => {
    fs.mkdirSync(state.COLAB_DIR, { recursive: true });
    // repos.txt
    const text = readReposTxt();
    const inTxt = reposTxtEntries(text).includes(target);
    if (!inTxt) {
      let base;
      if (text == null) base = REPOS_TXT_HEADER + '\n';
      else base = text === '' || text.endsWith('\n') ? text : text + '\n';
      state.atomicWrite(reposTxtPath(), base + target + '\n');
    }
    // config.json repos[]
    const cfg = state.loadConfig();
    const inCfg = cfg.repos.includes(target);
    if (!inCfg) { cfg.repos.push(target); state.saveConfig(cfg); }
    return { inTxt, inCfg };
  });

  if (res.inTxt && res.inCfg) { print(`Already registered in both registries: ${target}`); return 0; }
  const added = [];
  if (!res.inTxt) added.push('repos.txt');
  if (!res.inCfg) added.push('config.json');
  const healed = (res.inTxt || res.inCfg) ? '  (other registry already had it — drift healed)' : '';
  print(`Registered ${target}`);
  print(`  added to: ${added.join(' + ')}${healed}`);
  return 0;
}

function registerRemove(target) {
  const res = state.withLock(() => {
    const text = readReposTxt();
    let removedTxt = false;
    if (text != null) {
      const lines = text.split(/\r?\n/);
      const kept = lines.filter((l) => l.replace(/#.*$/, '').trim() !== target);
      removedTxt = kept.length !== lines.length;
      if (removedTxt) state.atomicWrite(reposTxtPath(), kept.join('\n'));
    }
    const cfg = state.loadConfig();
    const before = cfg.repos.length;
    cfg.repos = cfg.repos.filter((r) => r !== target);
    const removedCfg = cfg.repos.length !== before;
    if (removedCfg) state.saveConfig(cfg);
    return { removedTxt, removedCfg };
  });

  if (!res.removedTxt && !res.removedCfg) { print(`Was not registered in either registry: ${target}`); return 0; }
  const from = [];
  if (res.removedTxt) from.push('repos.txt');
  if (res.removedCfg) from.push('config.json');
  print(`Unregistered ${target}`);
  print(`  removed from: ${from.join(' + ')}`);
  return 0;
}

function registerList() {
  const txtEntries = reposTxtEntries(readReposTxt());
  const cfgRepos = state.loadConfig().repos || [];
  const all = [...new Set([...txtEntries, ...cfgRepos])].sort();
  if (all.length === 0) { print('No repos registered. Add one with: colab register [<path>]'); return 0; }

  let drift = 0;
  const rows = all.map((e) => {
    const inTxt = txtEntries.includes(e);
    const inCfg = cfgRepos.includes(e);
    const slug = isSlug(e);
    let note = '';
    if (slug) note = 'slug — audit-only';
    else if (inTxt && !inCfg) { note = 'DRIFT: only in repos.txt'; drift++; }
    else if (!inTxt && inCfg) { note = 'DRIFT: only in config.json'; drift++; }
    return [inTxt ? 'T' : '-', slug ? 'n/a' : (inCfg ? 'C' : '-'), e, note];
  });
  print(table(rows, ['TXT', 'CFG', 'REPO', 'NOTE']));
  if (drift) {
    print('');
    print(`${drift} repo(s) drifted between the two registries.`);
    print('  Fix: `colab register <path>` re-syncs both, or `colab register <path> --remove` drops from both.');
    return 1;
  }
  return 0;
}

// ---------------------------------------------------------------------------
// config (show / manage the aggregation inputs)
// ---------------------------------------------------------------------------

const HELP_CONFIG = `colab config [show|add-repo <path>|rm-repo <path>|add-reserved-file <path>|rm-reserved-file <path>|set <key> <value>]

  show                       print resolved config, file paths, and the aggregated reserved set
  add-repo <path>            add a repo root to scan for .github/project.yml reserved ports
  rm-repo <path>             remove a repo root
  add-reserved-file <path>   add a machine-local reserved-ports file (~ is expanded); its ports join
                             the reserved set (lenient parse: whitespace ints per line, # comments)
  rm-reserved-file <path>    remove a reserved-ports file
  set <key> <value>          set claimTTLHours | portRange | worktreeSubdir
`;

function cmdConfig(argv) {
  const sub = argv[0];
  const cfg = state.loadConfig();
  if (!sub || sub === 'show') {
    print(`state:  ${state.STATE_FILE}`);
    print(`config: ${state.CONFIG_FILE}`);
    print(JSON.stringify(cfg, null, 2));
    const reserved = ports.reservedSet(cfg, knownRepos(cfg));
    print(`reserved ports (${reserved.size}): ${[...reserved.keys()].sort((a, b) => a - b).join(', ') || '—'}`);
    return 0;
  }
  if (sub === 'add-repo') {
    const p = path.resolve(argv[1] || '');
    if (!argv[1]) throw new UserError('add-repo needs a path');
    if (!cfg.repos.includes(p)) cfg.repos.push(p);
    state.saveConfig(cfg); print(`repos: ${cfg.repos.join(', ')}`); return 0;
  }
  if (sub === 'rm-repo') {
    const p = path.resolve(argv[1] || '');
    cfg.repos = cfg.repos.filter((r) => r !== p);
    state.saveConfig(cfg); print(`repos: ${cfg.repos.join(', ') || '(none)'}`); return 0;
  }
  if (sub === 'add-reserved-file') {
    if (!argv[1]) throw new UserError('add-reserved-file needs a path');
    cfg.reservedFiles = cfg.reservedFiles || [];
    // Keep the path as written (may contain ~); expansion happens at read time.
    if (!cfg.reservedFiles.includes(argv[1])) cfg.reservedFiles.push(argv[1]);
    state.saveConfig(cfg);
    const found = ports.parseReservedFile(argv[1]);
    print(`reservedFiles: ${cfg.reservedFiles.join(', ')}`);
    print(`  ${argv[1]} → ${found.length} port(s) parsed`);
    return 0;
  }
  if (sub === 'rm-reserved-file') {
    if (!argv[1]) throw new UserError('rm-reserved-file needs a path');
    cfg.reservedFiles = (cfg.reservedFiles || []).filter((f) => f !== argv[1]);
    state.saveConfig(cfg); print(`reservedFiles: ${cfg.reservedFiles.join(', ') || '(none)'}`); return 0;
  }
  if (sub === 'set') {
    const [k, v] = [argv[1], argv[2]];
    if (!k || v === undefined) throw new UserError('set needs <key> <value>');
    if (k === 'claimTTLHours') cfg[k] = parseFloat(v);
    else if (k === 'portRange' || k === 'worktreeSubdir') cfg[k] = v;
    else throw new UserError(`Unknown config key "${k}"`);
    state.saveConfig(cfg); print(`${k} = ${cfg[k]}`); return 0;
  }
  return print(HELP_CONFIG);
}

// ---------------------------------------------------------------------------
// template — copy a handbook workflow template into a repo, STAMPED with the
// handbook's current version. The stamp (`# colab-handbook: <name> @ <version>`) is
// what audit/audit.mjs reads to tell an adopter their copy has fallen behind a changed
// template. Copy-and-own is deliberate: these are never called remotely. Making
// copy+stamp one command matters because a manual stamp is the step people skip.
// ---------------------------------------------------------------------------

/** Handbook root + templates dir, relative to this script (tools/colab). */
function handbookPaths() {
  const root = path.resolve(__dirname, '..');
  return { root, templatesDir: path.join(root, 'templates') };
}

/** Current handbook version = nearest tag; 'v0' before the first tag exists. */
function handbookVersion(root) {
  const d = git.git(['describe', '--tags', '--abbrev=0'], root);
  return d.ok && d.stdout ? d.stdout : 'v0';
}

function listTemplates(templatesDir) {
  try {
    return fs.readdirSync(templatesDir)
      .filter((f) => /\.ya?ml$/.test(f))
      .map((f) => f.replace(/\.ya?ml$/, ''))
      .sort();
  } catch (_) {
    throw new UserError(`Cannot read handbook templates dir: ${templatesDir}`);
  }
}

const HELP_TEMPLATE = `colab template [<name>] [--dest <path>] [--repo <path>] [--force]

Copy a colab-handbook workflow template into a repo, STAMPED with the handbook's current
version. The stamp lets the audit tell you later when the source template has moved on.

  colab template                    list available templates + current handbook version
  colab template <name>             copy templates/<name>.yml → <repo>/.github/workflows/<name>.yml
  colab template <name> --dest F    copy to an explicit file F
                                    (adopters usually want --dest .github/workflows/ci.yml)

Options:
  --repo <path>   target repo root for the default destination (default: git root of cwd)
  --force         overwrite an existing destination. You OWN the copy — local edits are lost.

The copied file gets one line prepended:
  # colab-handbook: <name> @ <version>
These templates are NEVER called remotely — copy, edit, own. When the audit flags your
copy as behind a changed template, review the diff and re-copy to re-stamp.
`;

function cmdTemplate(argv) {
  const opts = parseArgs(argv, {
    values: { '--dest': 'dest', '--repo': 'repo' },
    flags: { '--force': 'force', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_TEMPLATE);

  const { root, templatesDir } = handbookPaths();
  const available = listTemplates(templatesDir);
  const version = handbookVersion(root);

  // No name → list.
  const name = opts._[0];
  if (!name) {
    print(`colab-handbook templates (handbook ${version}):`);
    for (const t of available) print(`  ${t}`);
    print('');
    print('Copy one:  colab template <name> [--dest <path>] [--repo <path>]');
    print('The CLAUDE block (templates/repo-CLAUDE-block.md) is pasted by hand — see the note in that file.');
    return 0;
  }

  const stem = name.replace(/\.ya?ml$/, '');
  const srcFile = path.join(templatesDir, `${stem}.yml`);
  if (!fs.existsSync(srcFile)) {
    throw new UserError(`No template "${stem}". Available: ${available.join(', ') || '(none)'}`);
  }

  // Destination: explicit --dest, else <repo>/.github/workflows/<name>.yml.
  let destFile;
  if (opts.dest) {
    destFile = path.resolve(opts.dest);
  } else {
    const repoAbs = resolveRepo(opts);
    destFile = path.join(repoAbs, '.github', 'workflows', `${stem}.yml`);
  }

  if (fs.existsSync(destFile) && !opts.force) {
    warn(`${destFile} already exists — not overwriting.`);
    print('Compare your copy against the current template:');
    print(`  diff "${destFile}" "${srcFile}"`);
    print('Re-copy with --force to replace it (you own that file; local edits are lost).');
    return 1;
  }

  if (version === 'v0') {
    warn('handbook has no tags yet — stamping @ v0. Tag the handbook, then re-copy to stamp a real version.');
  }

  const body = fs.readFileSync(srcFile, 'utf8');
  const stampLine = `# colab-handbook: ${stem} @ ${version}\n`;
  fs.mkdirSync(path.dirname(destFile), { recursive: true });
  fs.writeFileSync(destFile, stampLine + body);

  print(`✓ ${stem} @ ${version} → ${destFile}`);
  print('  stamped. Walk its # EDIT: markers, declare your toolchain, then commit. You own this file now.');
  return 0;
}

// ---------------------------------------------------------------------------
// update — sweep the machine's fleet registry and refresh stamped handbook artifacts.
//
// The handbook cannot push to its consumers: the fleet registry is machine-local and
// deliberately uncommitted (this repo is public; a list of private repo paths is not something
// to publish — CONVENTIONS §8). So this is an OUTWARD SWEEP from the machine that holds the
// list, not a broadcast from the handbook.
//
// Three refusals define this command, and each one protects something specific:
//
//   1. REPORT BY DEFAULT, write only under --apply. Copy-and-own (§7) means a repo may
//      legitimately hand-edit its CI; a tool that silently overwrote it would destroy the very
//      principle §7 exists to serve.
//   2. NEVER COMMIT, STAGE OR PUSH. Every repo has its own tier and trunk rules — committing
//      into a Tier A repo's `dev` would have this tool violate the handbook it enforces. It
//      writes files into the working tree and stops; the human commits through that repo's flow.
//   3. NEVER TOUCH A DIVERGED COPY, even with --apply. "Diverged" means someone edited it, and
//      we cannot know what their edit was for.
//
// The classification (see classifyStamped in lib/stamp.js) rests on two git reads against the
// handbook's own history, NOT on comparing version strings: `git log <stamp>..HEAD` scoped to the
// template answers "did this actually change?", and `git show <stamp>:templates/<name>` answers
// "was this copy pristine when it was made?". Comparing versions alone would mark the whole fleet
// stale on every release, including releases that touched nothing anyone copied.
// ---------------------------------------------------------------------------

/** Repo-relative candidates for the CLAUDE conventions block. */
const CLAUDE_FILE = 'CLAUDE.md';

/**
 * Inspect one registry entry. Returns { label, path, kind, artifacts[], note }.
 * `artifacts` entries: { file, template, state, from, to, reason, applicable }.
 */
function inspectRepo(entry, ctx) {
  const label = entryLabel(entry);

  if (isSlug(entry)) {
    return { label, path: null, kind: 'slug', artifacts: [],
      note: 'owner/name slug — audit-only, no working tree on this machine to update' };
  }
  const abs = path.resolve(entry.startsWith('~') ? path.join(os.homedir(), entry.slice(1)) : entry);
  if (!fs.existsSync(abs)) {
    return { label, path: abs, kind: 'missing', artifacts: [], note: 'path does not exist on this machine' };
  }
  // Skip self. A stamp means "copied from version X"; this repo IS X, and its own ci.yml is
  // purpose-written rather than copied — treating it as an adopter is a guaranteed false positive.
  // Identity is by git common dir, not by path string: this CLI resolves its root from its own
  // file, so running it out of a worktree gives a different spelling of the same repo than the
  // fleet registry holds. The string test missed that and reported the handbook as its own adopter.
  if (stamp.isHandbookItself(abs, ctx.handbookRoot)) {
    return { label, path: abs, kind: 'handbook', artifacts: [], note: 'the handbook itself — skipped' };
  }

  const artifacts = [];
  const read = (rel) => {
    const f = path.join(abs, rel);
    try { return fs.existsSync(f) ? fs.readFileSync(f, 'utf8') : null; } catch (_) { return null; }
  };

  // --- workflow copies: whole-file copies, so a pristine one can be regenerated exactly ---
  const wfDir = path.join(abs, '.github', 'workflows');
  let wfs = [];
  try { wfs = fs.existsSync(wfDir) ? fs.readdirSync(wfDir).filter((f) => /\.ya?ml$/.test(f)).sort() : []; }
  catch (_) { wfs = []; }

  for (const wf of wfs) {
    const rel = `.github/workflows/${wf}`;
    const text = read(rel);
    const st = stamp.parseWorkflowStamp(text);
    if (st) {
      const c = stamp.classifyStamped({
        root: ctx.handbookRoot, hb: ctx.hb, tmplNames: ctx.tmplNames,
        templateName: st.name, stampVersion: st.version, localText: text, comparable: true,
      });
      artifacts.push({ file: rel, template: st.name, applicable: c.state === 'behind', ...c });
    } else {
      // No stamp: ask what the CONTENT says, not what the filename says. `unstamped` claims a
      // handbook lineage and points at a real template; `unrelated` is the file whose name
      // collides with a template it never came from — reported here precisely BECAUSE this is
      // the command whose --force would overwrite it. Anything else stays silent: somebody's
      // own workflow is none of our business.
      const prov = stamp.workflowProvenance(text, wf.replace(/\.ya?ml$/, ''), ctx.tmplNames);
      const finding = stamp.unstampedFinding(prov);
      if (finding) {
        artifacts.push({ file: rel, template: prov.template, state: finding.state,
          from: null, to: ctx.hb.version, applicable: false, reason: finding.reason });
      }
    }
  }

  // --- the CLAUDE conventions block ---
  //
  // REPORTED, NEVER WRITTEN — and this is a deliberate departure from treating every stamped
  // artifact alike. The block is a FRAGMENT pasted into a larger hand-written file, and the
  // template ships PLACEHOLDERS the adopter fills in (`<A|B>`, `<dev|main>`). So a correctly
  // adopted block never matches the template byte-for-byte: divergence is undecidable here, and
  // regenerating it would overwrite a repo's real tier/trunk with angle brackets — and take the
  // rest of its CLAUDE.md with it. We classify it (current/behind) and hand it to a human.
  const claude = read(CLAUDE_FILE);
  if (claude) {
    const st = stamp.parseClaudeStamp(claude);
    if (st) {
      const c = stamp.classifyStamped({
        root: ctx.handbookRoot, hb: ctx.hb, tmplNames: ctx.tmplNames,
        templateName: null, stampVersion: st.version, localText: claude, comparable: false,
      });
      artifacts.push({
        file: CLAUDE_FILE, template: 'repo-CLAUDE-block', applicable: false, ...c,
        reason: c.state === 'behind'
          ? 'the conventions block moved — re-paste templates/repo-CLAUDE-block.md by hand and bump its stamp (it has placeholders only you can fill, so this is never automated)'
          : c.reason,
      });
    } else if (stamp.looksLikeHandbookClaude(claude)) {
      artifacts.push({ file: CLAUDE_FILE, template: 'repo-CLAUDE-block', state: 'unstamped',
        from: null, to: ctx.hb.version, applicable: false,
        reason: 'has the conventions block but no stamp — re-paste the current block including its `<!-- colab-handbook @ ... -->` line' });
    }
  }

  const note = artifacts.length ? null : 'no stamped handbook artifacts — nothing adopted here yet';
  return { label, path: abs, kind: 'local', artifacts, note };
}

/** Two path segments read better than one in a report: `company/project`. */
function entryLabel(entry) {
  if (isSlug(entry)) return entry;
  const r = entry.replace(/\/+$/, '');
  const parent = path.basename(path.dirname(r));
  return parent && parent !== '/' && parent !== '.' ? `${parent}/${path.basename(r)}` : path.basename(r);
}

/** Rewrite a behind-but-pristine workflow copy as the current template, freshly stamped. */
function refreshArtifact(repo, art, ctx) {
  const src = path.join(ctx.templatesDir, `${art.template}.yml`);
  if (!fs.existsSync(src)) return { ok: false, err: `template ${art.template}.yml is not in the handbook` };
  const body = fs.readFileSync(src, 'utf8');
  const dest = path.join(repo.path, art.file);
  try {
    fs.mkdirSync(path.dirname(dest), { recursive: true });
    fs.writeFileSync(dest, stamp.stampLine(art.template, ctx.hb.version) + body);
    return { ok: true };
  } catch (e) {
    return { ok: false, err: e.message };
  }
}

const HELP_UPDATE = `colab update [<repo> ...] [--apply] [--json] [--quiet]

Sweep this machine's fleet registry and report which repos' stamped handbook artifacts have
fallen behind — then, with --apply, refresh the ones that are safe to refresh.

  <repo> ...   limit the sweep (match an absolute path, or a trailing path segment such as
               "my-repo" or "company/project"). Default: every registered repo.
  --apply      WRITE the refreshable copies. Without it nothing on disk is touched.
  --quiet, -q  only show repos with something to say
  --json       machine-readable

Each stamped artifact is classified:
  current     the stamp is the handbook's version, or the template genuinely has not changed
              since that stamp (checked with git log, not by comparing version strings — so a
              release that touched nothing you copied does not mark you stale)
  behind      the stamp is older, the template really did change, AND your copy is still
              pristine as of its own stamp -> safe to regenerate. Only these are written.
  diverged    your copy does not match the template as of ITS OWN stamp: it was hand-edited.
              Copy-and-own makes that legitimate, so it is REPORTED AND NEVER WRITTEN.
  unstamped   the CONTENT matches text only our templates contain, but there is no stamp:
              lineage unknown, so replacing it could destroy edits nobody can see. The row
              names the template the evidence points to — re-copy that one, deliberately.
  unrelated   its NAME matches a template but its content carries nothing of that template.
              A shared filename is a coincidence, not a lineage: this file is the repo's own
              and must NOT be re-copied over. Reported so nobody --forces it by mistake.
  n-a         cannot be assessed, always with a stated reason (an owner/name slug has no
              working tree here; a stamp from a tag this checkout lacks; an unknown template).

What this command will NOT do, by design:
  • It never commits, stages or pushes. Every repo has its own tier and trunk rules; committing
    for you would make this tool violate the handbook it enforces. It writes files and stops —
    review with \`git diff\` and commit through that repo's own flow.
  • It never rewrites a diverged copy, even with --apply.
  • It never rewrites the CLAUDE conventions block: that block has placeholders only you can
    fill, so it is reported for a hand re-paste.
  • It skips the handbook repo itself.

Exit code: 0 when nothing is behind, 1 when anything is behind (scriptable), 2 on usage error.
`;

function cmdUpdate(argv) {
  const opts = parseArgs(argv, {
    flags: { '--apply': 'apply', '--json': 'json', '--quiet': 'quiet', '-q': 'quiet', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_UPDATE);

  const { root, templatesDir } = handbookPaths();
  const hb = stamp.handbookInfo(root);
  const ctx = { handbookRoot: root, templatesDir, hb, tmplNames: stamp.templateNames(root) };

  const registryPath = reposTxtPath();
  const entries = reposTxtEntries(readReposTxt());
  if (!entries.length) {
    throw new UserError(`No repos registered (${registryPath}) — add one with: colab register [<path>]`);
  }

  // Positional filters: an absolute path, or any trailing path segment ("my-repo").
  const filters = opts._;
  const selected = filters.length
    ? entries.filter((e) => filters.some((f) => {
      if (e === f || e === path.resolve(f)) return true;
      const norm = e.replace(/\/+$/, '');
      return norm.endsWith(`/${f.replace(/^\/+|\/+$/g, '')}`);
    }))
    : entries;
  if (filters.length && !selected.length) {
    throw new UserError(`No registered repo matches: ${filters.join(', ')} — see \`colab register --list\``);
  }

  const repos = selected.map((e) => inspectRepo(e, ctx));

  // --- apply -------------------------------------------------------------
  // Only `behind` + `applicable` artifacts are eligible; everything else was already excluded by
  // the classification, which is where the refusals live.
  const written = [];
  const failed = [];
  if (opts.apply && !hb.untagged) {
    for (const r of repos) {
      for (const a of r.artifacts) {
        if (a.state !== 'behind' || !a.applicable) continue;
        const res = refreshArtifact(r, a, ctx);
        if (res.ok) { a.written = true; written.push({ repo: r.label, file: a.file, template: a.template, from: a.from, to: a.to }); }
        else { a.writeError = res.err; failed.push({ repo: r.label, file: a.file, err: res.err }); }
      }
    }
  }

  // --- tally -------------------------------------------------------------
  const all = repos.flatMap((r) => r.artifacts);
  const count = (s) => all.filter((a) => a.state === s).length;
  const summary = {
    repos: repos.length,
    artifacts: all.length,
    current: count('current'), behind: count('behind'), diverged: count('diverged'),
    unstamped: count('unstamped'), unrelated: count('unrelated'), na: count('n-a'),
    // Repos with no assessable artifact at all are counted SEPARATELY from artifact-level n-a:
    // they are repos, not artifacts, and folding them into the artifact tally would make the
    // arithmetic on that line stop adding up.
    skippedRepos: repos.filter((r) => !r.artifacts.length).length,
    refreshable: all.filter((a) => a.state === 'behind' && a.applicable && !a.written).length,
    written: written.length,
  };

  if (opts.json) {
    print(JSON.stringify({
      generated: nowISO(),
      handbook: { version: hb.version, untagged: hb.untagged, root },
      registry: registryPath,
      applied: !!opts.apply,
      repos, written, failed, summary,
    }, null, 2));
    return summary.behind > 0 ? 1 : 0;
  }

  // --- report ------------------------------------------------------------
  print(`registry:  ${registryPath}`);
  print(`handbook:  ${hb.version}${hb.untagged ? ' (untagged — stamp comparison inactive)' : ''}`);
  print('');
  if (hb.untagged) {
    warn('the handbook has no tags — there is no version line to compare against. Tag it, then re-run.');
    return 0;
  }

  const rows = [];
  for (const r of repos) {
    if (!r.artifacts.length) {
      if (!opts.quiet) rows.push([r.label, '—', 'n-a', r.note || 'nothing to assess']);
      continue;
    }
    for (const a of r.artifacts) {
      // `unrelated` is a "do not touch this" note, not a finding — it has no action, so it stays
      // out of the quiet view alongside `current`.
      if (opts.quiet && (a.state === 'current' || a.state === 'unrelated')) continue;
      const move = a.from ? `${a.from} → ${a.to}` : `→ ${a.to}`;
      const mark = a.written ? 'updated' : a.state;
      const detail = a.writeError ? `WRITE FAILED: ${a.writeError}` : `${move}  ${a.reason}`;
      rows.push([r.label, a.file, mark, detail]);
    }
  }
  if (rows.length) print(table(rows, ['REPO', 'ARTIFACT', 'STATE', 'DETAIL']));
  else print('Nothing to report — every stamped artifact is current.');

  print('');
  print(`${summary.repos} repo(s), ${summary.artifacts} handbook artifact(s): ` +
    `${summary.current} current, ${summary.behind} behind, ${summary.diverged} diverged, ` +
    `${summary.unstamped} unstamped, ${summary.na} n-a` +
    (summary.unrelated ? `, ${summary.unrelated} unrelated (name clash only — not ours).` : '.'));
  if (summary.skippedRepos) {
    print(`${summary.skippedRepos} repo(s) had nothing to assess (nothing adopted, an audit-only slug, a missing path, or the handbook itself).`);
  }

  if (opts.apply) {
    if (written.length) {
      print(`Refreshed ${written.length} file(s) to ${hb.version}:`);
      for (const w of written) print(`  ✓ ${w.repo}  ${w.file}  (${w.template} ${w.from} → ${w.to})`);
      print('');
      print('NOTHING was committed, staged or pushed — that is deliberate: each repo has its own');
      print('tier and trunk rules. Review with `git diff` and commit through that repo\'s own flow.');
    } else {
      print('Nothing was refreshable — no files were written.');
    }
    for (const f of failed) warn(`could not write ${f.repo} ${f.file}: ${f.err}`);
  } else if (summary.refreshable) {
    print(`${summary.refreshable} pristine copy/copies can be refreshed: re-run with --apply.`);
  }

  if (summary.diverged || summary.unstamped) {
    print(`${summary.diverged} diverged + ${summary.unstamped} unstamped need a human — never written by this command.`);
    print('  Review the diff, take what you want, then re-copy the template NAMED IN THAT ROW.');
    print('  Where a row names none, its lineage is unproven — establish it before stamping one.');
  }
  if (summary.unrelated) {
    print(`${summary.unrelated} unrelated file(s) share a template's name without its content — leave them alone.`);
  }

  return summary.behind > 0 ? 1 : 0;
}

// ---------------------------------------------------------------------------
// ship — the ONE sanctioned door for code-wrap Phase B (session branch → the base it was cut from).
//
// Autonomy is granted by the REPO (project.yml `autonomy: auto-trunk`), never by the caller: a
// human decides which repos an agent may auto-merge, and --force cannot override that. ship never
// touches main (when trunk != main), never tags, never promotes — those stay human. Every step is
// gated; any failure aborts cleanly BEFORE the push, so the target is never left half-shipped.
//
// The target is the worktree's RECORDED BASE, which is trunk unless the session was cut from a
// declared integration line. Following the base rather than resolving trunk afresh is not a
// convenience: shipping a line-based branch into trunk would carry the whole line along inside one
// squash commit. Merging a line itself into trunk is refused here in every configuration.
// ---------------------------------------------------------------------------

// Files that are regenerated, not authored — a merge conflict here is resolvable by re-running the
// repo's codegen, so it doesn't force a human. Repos extend this via project.yml `generated: [...]`.
const DEFAULT_GENERATED = [
  'package-lock.json', 'pnpm-lock.yaml', 'yarn.lock', 'composer.lock', 'Cargo.lock', 'go.sum',
  'dist/', 'build/', 'public/build/', '.astro/',
];

function escapeRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

/** Does a path look generated per the pattern list? `foo/` = prefix, `*` = wildcard, else exact/basename. */
function isGeneratedPath(file, patterns) {
  const base = file.split('/').pop();
  for (const pat of patterns) {
    if (pat.endsWith('/')) { if (file === pat.slice(0, -1) || file.startsWith(pat) || file.includes('/' + pat)) return true; }
    else if (pat.includes('*')) {
      const re = new RegExp('^' + pat.split('*').map(escapeRe).join('.*') + '$');
      if (re.test(file) || re.test(base)) return true;
    } else if (file === pat || base === pat) return true;
  }
  return false;
}

/** Parsed .github/project.yml doc, or {} if absent/unparseable. */
function projectDoc(repoAbs) {
  try { return require('./lib/yaml').parse(fs.readFileSync(path.join(repoAbs, '.github', 'project.yml'), 'utf8')) || {}; }
  catch (_) { return {}; }
}

/** Trunk for a repo: project.yml `trunk:` → origin/HEAD. */
function resolveTrunk(repoAbs, doc) {
  if (doc && doc.trunk) return String(doc.trunk);
  return git.detectTrunk(repoAbs);
}

/**
 * Declared long-lived integration lines (project.yml `integration:`), or [].
 *
 * These are DEVELOPMENT integration points: a worktree may be cut from one and shipped back into
 * one. Nothing in promote / tag / deploy reads this — that is the field's whole guarantee, so keep
 * every use of it on the ship/worktree side of the CLI (project.schema.md).
 *
 * Entries equal to trunk or to `main` are dropped rather than honoured: the audit reports them as
 * findings, and a malformed descriptor must not be the thing that hands a session a base with a
 * path to production. Fail closed, report loudly elsewhere.
 */
function resolveIntegration(repoAbs, doc, trunk) {
  const raw = doc && doc.integration;
  if (!Array.isArray(raw)) return [];
  return raw
    .map((b) => (b === null || b === undefined ? '' : String(b).trim()))
    .filter((b) => b && b !== trunk && b !== 'main' && b !== 'trunk');
}

/** The set of refs a worktree may legitimately be based on: trunk ∪ integration. */
function allowedBases(repoAbs, doc, trunk) {
  return [trunk, ...resolveIntegration(repoAbs, doc, trunk)].filter(Boolean);
}

/**
 * The base a session branch was cut from, and therefore the branch it ships back into.
 *
 * Recorded per worktree at creation (`state.worktrees[name].base`) because it is a per-machine,
 * per-session fact — the repo declares which bases are LEGAL, the state records which one was
 * USED. Worktrees created before this existed have no `base`, so trunk is the fallback: that is
 * what they were in fact cut from.
 *
 * Base and ship target are ONE decision, not two. A worktree cut from a long-lived line and shipped
 * into trunk would drag the whole line in behind it as a single squash commit that reads like a
 * small change — which is exactly the accident `integration:` exists to make impossible.
 */
function resolveBase(st, repoAbs, worktreeName, trunk) {
  const wt = worktreeName ? st.worktrees[worktreeName] : null;
  const recorded = wt && wt.base ? String(wt.base) : '';
  return recorded || trunk;
}

/**
 * Is <branch>'s content already in the branch it would ship into? A thin adapter over the shared
 * rule in lib/landed.js — see that file for why "commits ahead" is the wrong question, why
 * `git cherry` does not fix it, and exactly what the rule does not cover.
 *
 * `base` is the branch's recorded base when the caller knows it, trunk otherwise. Asking a
 * line-based branch about trunk would report a fully-shipped branch as enormous cargo.
 *
 * Returns { contained, ambiguous, verdict } — `ambiguous` covers missing refs, a conflicting
 * rewrite, and a git too old for the content test. Callers must treat it as NOT contained: this
 * decides whether a worktree is a teardown candidate, and being wrong toward "contained" is the
 * direction that loses work.
 *
 * (The previous implementation read `merge-tree` exit code 1 as "a clean merge with changes". It is
 * a CONFLICT — a clean merge with changes also exits 0, with a differing tree — so a branch whose
 * work trunk had rewritten was reported as a confident "not contained" rather than an honest
 * "cannot tell". Same action, worse information.)
 */
function branchContainedInTrunk(repoAbs, branch, base) {
  const target = base || resolveTrunk(repoAbs, projectDoc(repoAbs));
  if (!target || target === branch) return { contained: false, ambiguous: true };
  const verdict = landed.landedState(repoAbs, target, branch);
  return { contained: verdict.state === 'landed', ambiguous: verdict.state === 'unknown', verdict };
}

/** New migration files introduced on <branch> vs <trunk> (Laravel + Prisma layouts). */
function newMigrations(mainRoot, trunk, branch) {
  const r = git.git(['diff', '--name-only', `${trunk}...${branch}`], mainRoot);
  if (!r.ok) return [];
  return r.stdout.split('\n').filter(Boolean)
    .filter((f) => /(^|\/)database\/migrations\//.test(f) || /(^|\/)prisma\/migrations\//.test(f));
}

/**
 * Read the branch's non-merge commits (newest-first) as {subject, body} records.
 *
 * Split out from message composition on purpose: this half touches git, the other half is pure and
 * lives in lib/squash.js where CI can unit-test it. `tools/colab` has no test harness, which is how
 * the "newest commit titles the squash" bug survived long enough to reach a published tag.
 */
function branchCommits(mainRoot, trunk, branch) {
  const logShas = git.git(['log', `${trunk}..${branch}`, '--no-merges', '--format=%H'], mainRoot);
  const shas = logShas.ok ? logShas.stdout.split('\n').filter(Boolean) : [];
  const list = shas.length ? shas : [git.git(['rev-parse', branch], mainRoot).stdout].filter(Boolean);
  return list.map((sha) => {
    const full = git.git(['log', '-1', '--format=%B', sha], mainRoot).stdout;
    const nl = full.indexOf('\n');
    return {
      sha,
      subject: (nl === -1 ? full : full.slice(0, nl)).replace(/\s+$/, ''),
      body: (nl === -1 ? '' : full.slice(nl + 1)).replace(/^\n+/, '').replace(/\s+$/, ''),
    };
  });
}

/**
 * Default squash-commit message when --message is absent.
 *
 * The subject comes from the branch's HIGHEST-WEIGHT commit, not its newest one — see lib/squash.js
 * for why (short version: the newest commit on a well-run branch is the docs pass, so features
 * shipped titled `docs:` and vanished from the changelog). The body keeps the design that was never
 * at fault: `Closes #N` per claimed issue, the other subjects as bullets, `chore(sync)` filtered,
 * Co-Authored-By / Claude-Session trailers preserved.
 */
function buildSquashMessage(mainRoot, trunk, branch, issues) {
  return squash.composeSquashMessage(branchCommits(mainRoot, trunk, branch), issues);
}

const HELP_SHIP = `colab ship [--repo <path>] [--worktree <name> | --branch <br>] [--message "<msg>"] [--keep-worktree] [--delete-branch] [--dry]

The ONE sanctioned door for code-wrap Phase B: squash-merge a session branch into the BASE IT WAS
CUT FROM — trunk for an ordinary session, or the declared integration line recorded on its worktree
(project.yml \`integration:\`). Autonomy is granted by the repo's .github/project.yml
(\`autonomy: auto-trunk\`) — NOT by any flag. Without that grant, ship refuses and a human must run
Phase B. ship NEVER touches main (when trunk≠main), NEVER tags, NEVER promotes.

Base and target are ONE decision. A branch cut from a long-lived line and shipped into trunk would
drag the entire line in behind it, as a single squash commit that reads like a small change — so
ship follows the recorded base and refuses to retarget. Shipping a declared LINE into trunk is
refused outright, even under autonomy: auto-trunk: a long divergence meeting the branch that
promotes is an integration event of the same weight as a promotion, and stays human.

Sequence (each step gated; any failure aborts before the push — the target is never half-shipped):
  a. autonomy gate      repo must grant auto-trunk (no --force override)
  b. preconditions      target CI alive+green · no new migrations on branch · trunk checkout clean
                        (an integration line with NO runs at all borrows trunk's verdict, advisory —
                        an ungated line is a normal early state; a RED line still blocks)
  c. B0 sync            merge the target INTO the branch; non-generated conflict → abort (human merge);
                        generated-only conflict → repo's .colab/hooks/pre-ship regenerates, else abort
  d. B1 squash          re-check CI green, then squash-merge branch → target (Closes every claimed issue).
                        Into trunk that happens in the main checkout; into a line it happens in an
                        EPHEMERAL worktree, so the main checkout never leaves trunk.
  e. B2 push            push the target (COLAB_SHIP=1 in env so a pre-push-guard lets it through)
  f. B3 teardown        colab worktree rm (releases claims + ports + ✅ comments) unless --keep-worktree.
                        The BRANCH IS KEPT — pass --delete-branch to remove it (local + remote).
  g. B4 verify + h.     confirm each issue auto-closed; post "🚢 Shipped to <trunk>" per issue

The default squash subject is the branch's HIGHEST-WEIGHT commit (breaking > feat > fix > perf >
refactor > docs > test > chore, ties to the oldest) — NOT its newest commit, which on a well-run
branch is the docs pass and used to retitle whole features as \`docs:\`, hiding them from the
release notes. The body is unchanged: Closes per issue, other subjects as bullets, footers kept.

B3 KEEPS the branch by default. Deleting refs from a shared remote is not something this command
does unasked, however certain it is that the content landed: reporting is safe and reversible,
deleting is neither. The accepted cost is that shipped branches accumulate — and because a squash
leaves no ancestry, \`git branch --merged\` can never list them, so \`colab doctor\` is where you
find them. Treat that list as routine maintenance, not as an alarm.

\`--delete-branch\` opts in: local + remote, only AFTER trunk is pushed, with \`branch -D\` (a
squashed branch is not "merged" as far as git is concerned). Best-effort — a failure warns rather
than failing a ship that already succeeded. Passing it together with --keep-worktree is refused
with a warning, because git will not delete a branch that is still checked out.

Options:
  --repo <path>       repo root (default: git root of cwd)
  --worktree <name>   the session worktree to ship (its branch + claims are used)
  --branch <br>       ship by branch name (its worktree, if any, is found in state)
  --message "<msg>"   subject for the squash commit (Closes trailer is always appended)
  --keep-worktree     do not remove the worktree after shipping
  --delete-branch     delete the branch (local + remote) after shipping — off by default
  --dry               print the plan + precondition table and change NOTHING
`;

/**
 * B3 (second half): what happens to the branch whose content has just landed on trunk.
 *
 * THE DEFAULT IS TO KEEP IT. Deleting requires an explicit `--delete-branch`.
 *
 * This premise has now been wrong twice in opposite directions, so state it exactly. Originally a
 * comment in buildSquashMessage justified preserving the newest commit verbatim by claiming "the
 * branch is deleted at B3" — nothing in the CLI deleted anything, so the branch always survived.
 * That was then fixed by making B3 delete. The operator reversed it: an agent removing refs from a
 * SHARED REMOTE is the wrong default however well-verified the deletion is, because reporting is
 * safe and reversible while deleting is neither. So the branch survives again — but now by
 * decision, documented, with an opt-in, instead of by an unimplemented comment.
 *
 * The consequence is accepted deliberately: shipped branches accumulate. `git branch --merged
 * <trunk>` cannot find them (a squash leaves no ancestry, which is also why deletion needs `-D`
 * rather than `-d`), so `colab doctor` reporting them is the mitigation, not a backstop.
 *
 * When deletion IS requested: it runs only after B2 pushed trunk, so the content is durable on the
 * remote before the ref goes. It refuses to touch trunk or `main` under any circumstances, and
 * every failure is a warning — a protected branch or a missing remote must not fail a ship that
 * already succeeded.
 */
function handleShippedBranch(repoAbs, trunk, branch, { deleteBranch = false, worktreeKept = false, integration = [] } = {}) {
  if (!branch) return;
  if (!deleteBranch) {
    print(`  keeping branch ${branch} (default; --delete-branch to remove it, or \`colab doctor\` to list what has accumulated)`);
    return;
  }
  if (branch === trunk || branch === 'main' || integration.includes(branch)) { // belt-and-braces; cmdShip already refuses these
    warn(`refusing to delete "${branch}" — it is the trunk, main, or a declared integration line`);
    return;
  }
  if (worktreeKept) {
    // Both flags passed. git will not delete a checked-out branch, so honour the safer one and say
    // why, rather than attempting a delete that is guaranteed to fail.
    warn(`--delete-branch ignored for ${branch}: its worktree was kept (--keep-worktree), so the branch is still checked out`);
    return;
  }
  const del = git.git(['branch', '-D', branch], repoAbs);
  if (del.ok) print(`  deleted local branch ${branch}`);
  else warn(`could not delete local branch ${branch}: ${del.stderr.split('\n')[0] || 'unknown error'}`);

  // Remote: only if it is actually there. Checked against the local remote-tracking ref rather than
  // the network, so an offline ship still finishes instead of hanging on ls-remote.
  const onRemote = git.git(['rev-parse', '--verify', '--quiet', `refs/remotes/origin/${branch}`], repoAbs).ok;
  if (!onRemote) return;
  const rdel = git.run('git', ['push', 'origin', '--delete', branch], { cwd: repoAbs, env: { ...process.env, COLAB_SHIP: '1' } });
  if (rdel.ok) print(`  deleted origin/${branch}`);
  else warn(`could not delete origin/${branch}: ${rdel.stderr.split('\n')[0] || 'unknown error'} — delete it by hand`);
}

/** Resolve the session (branch, worktree name/path, claimed issue numbers) from --worktree/--branch. */
function resolveShipSession(st, repoAbs, opts) {
  let name = null, branch = null, wtPath = null;
  let session = '', sessionName = '';
  if (opts.worktree) {
    const wt = st.worktrees[opts.worktree];
    if (!wt) throw new UserError(`No worktree "${opts.worktree}" in state`);
    name = wt.name; branch = wt.branch; wtPath = wt.path; session = wt.session || ''; sessionName = wt.sessionName || '';
  } else if (opts.branch) {
    branch = opts.branch;
    const wt = Object.values(st.worktrees).find((w) => w.repo === repoAbs && w.branch === branch);
    if (wt) { name = wt.name; wtPath = wt.path; session = wt.session || ''; sessionName = wt.sessionName || ''; }
  } else {
    throw new UserError('ship needs --worktree <name> or --branch <br>');
  }
  // Claimed issues for this session: by worktree if we have one, else by branch.
  const claims = Object.values(st.claims)
    .filter((c) => c.repo === repoAbs && (name ? c.worktree === name : c.branch === branch));
  const issues = claims.map((c) => normIssueNum(c.issue)).sort((a, b) => a - b);
  if (!session && !sessionName) { // fall back to a claim's identity
    const withId = claims.find((c) => c.session || c.sessionName);
    if (withId) { session = withId.session || ''; sessionName = withId.sessionName || ''; }
  }
  return { name, branch, wtPath, issues, session, sessionName };
}

function cmdShip(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo', '--worktree': 'worktree', '--branch': 'branch', '--message': 'message' },
    flags: { '--keep-worktree': 'keepWorktree', '--delete-branch': 'deleteBranch', '--dry': 'dry', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_SHIP);
  const repoAbs = resolveRepo(opts);
  if (!git.repoRoot(repoAbs)) throw new UserError(`${repoAbs} is not a git repo`);
  const doc = projectDoc(repoAbs);
  const st = state.loadState();
  const sess = resolveShipSession(st, repoAbs, opts);
  const trunk = resolveTrunk(repoAbs, doc);
  if (!trunk) throw new UserError('Could not determine trunk branch (set project.yml trunk:)');
  if (sess.branch === trunk) throw new UserError(`Refusing: --branch is the trunk itself (${trunk}) — nothing to ship`);

  // ---- the merge TARGET is the base the session was cut from, not trunk ----
  const integration = resolveIntegration(repoAbs, doc, trunk);
  // A declared line is never ship's cargo. Merging weeks of divergence into the branch that
  // promotes is an integration event of the same weight as a promotion, and `autonomy: auto-trunk`
  // grants no part of it — that field is about ordinary session branches.
  if (integration.includes(sess.branch)) {
    process.stderr.write(`✗ Refusing to ship "${sess.branch}" — it is a declared integration line (project.yml integration:).\n`);
    process.stderr.write(`  Merging a long-lived line into ${trunk} is a human act: it meets the branch that promotes, and\n`);
    process.stderr.write('  autonomy: auto-trunk does not cover it. Do it by hand, with COLAB_HUMAN=1 for the push.\n');
    return 1;
  }
  const target = resolveBase(st, repoAbs, sess.name, trunk);
  if (target !== trunk && !integration.includes(target)) {
    // The worktree records a base the repo no longer declares (the line was merged and dropped, or
    // project.yml was edited mid-session). Fail closed: silently retargeting at trunk is the exact
    // accident the recorded base exists to prevent.
    throw new UserError(
      `Worktree "${sess.name}" was cut from "${target}", which is no longer a declared base ` +
      `(allowed: ${allowedBases(repoAbs, doc, trunk).join(', ')}). Re-declare it in project.yml ` +
      '`integration:` or finish this merge by hand — ship will not retarget it at trunk for you.');
  }

  // ---- (a) AUTONOMY GATE — granted by the repo file, never by the caller ----
  const autonomy = doc.autonomy ? String(doc.autonomy) : 'manual';
  if (autonomy !== 'auto-trunk') {
    process.stderr.write(`✗ ${shortRepo(repoAbs)} does not grant auto-trunk (project.yml autonomy: ${doc.autonomy ? autonomy : 'absent'}).\n`);
    process.stderr.write('  A human must trigger Phase B. (Autonomy is granted by the repo, not by a flag — --force cannot override.)\n');
    return 1;
  }

  // ---- (b) PRECONDITIONS (report each ✓/✗) ----
  const gh = isGhUsable(repoAbs);
  const checks = [];
  // CI alive + green on the TARGET.
  //
  // On a declared line with NO runs at all, fall back to trunk's and say so. An ungated line is a
  // normal early state (the audit warns rather than fails on it, project.schema.md), and blocking
  // every ship into a line nobody has wired CI for would make the declared axis useless — which
  // pushes the work back to the undeclared workarounds. A line that HAS runs and is red still ✗:
  // once CI exists, it counts.
  let ciOk = false;
  const ciLabel = `${target === trunk ? 'trunk' : 'line'} CI green`;
  if (!gh) { checks.push(['✗', ciLabel, 'gh not usable (no auth / no origin) — cannot confirm CI']); }
  else {
    let run = git.ghRunLatest(repoAbs, target);
    let via = target;
    if (run && run.status === 'none' && target !== trunk) {
      run = git.ghRunLatest(repoAbs, trunk);
      via = `${trunk} (line "${target}" has no runs — ungated, advisory)`;
    }
    if (!run) checks.push(['✗', ciLabel, 'gh run list failed']);
    else if (run.status === 'completed' && run.conclusion === 'success') { ciOk = true; checks.push(['✓', ciLabel, `latest run on ${via}: success`]); }
    else checks.push(['✗', ciLabel, `latest run on ${via}: status=${run.status} conclusion=${run.conclusion || 'none'} (fail-to-start counts as not green)`]);
  }
  // No new migrations on the branch, measured against what it will merge into
  const migrations = newMigrations(repoAbs, target, sess.branch);
  const migOk = migrations.length === 0;
  checks.push([migOk ? '✓' : '✗', 'no new migrations', migOk ? `none vs ${target}` : `${migrations.length} present — human must run Phase B: ${migrations.join(', ')}`]);
  // The main checkout is on trunk and clean. Required whatever the target is: it is the repo's
  // at-rest invariant, and when the target is a line the merge happens in an ephemeral worktree
  // precisely so that this stays true.
  const headBranch = git.git(['rev-parse', '--abbrev-ref', 'HEAD'], repoAbs).stdout;
  const onTrunk = headBranch === trunk;
  const dirty = git.dirtyTracked(repoAbs);
  const treeOk = onTrunk && !dirty;
  checks.push([treeOk ? '✓' : '✗', 'trunk checkout ready',
    !onTrunk ? `main checkout is on "${headBranch}", not "${trunk}"` : (dirty ? 'tracked changes uncommitted in trunk checkout' : `on ${trunk}, clean`)]);

  const preOk = ciOk && migOk && treeOk;

  // ---- report the table ----
  print(`ship ${shortRepo(repoAbs)} · branch ${sess.branch} → ${target}` +
    (target === trunk ? '' : `  [declared line — NOT ${trunk}]`) + (opts.dry ? '  [DRY RUN]' : ''));
  print(`  issues: ${sess.issues.map((n) => '#' + n).join(' ') || '(none claimed)'}` + (sess.name ? ` · worktree ${sess.name}` : ''));
  print('');
  print(table(checks.map((c) => [c[0], c[1], c[2]]), ['', 'PRECONDITION', 'DETAIL']));
  print('');

  if (opts.dry) {
    print(preOk ? '→ READY: preconditions pass. Re-run without --dry to ship.' : '→ NOT READY: fix the ✗ rows above.');
    print(`  Plan: B0 sync ${target}→branch · B1 squash-merge → ` + target + ' · B2 push · B3 ' +
      (opts.keepWorktree ? 'keep worktree' : 'worktree rm') + ' + ' +
      (opts.deleteBranch && !opts.keepWorktree ? 'delete branch (local+remote)' : 'keep branch') +
      ' · B4 verify closed · post 🚢 summary');
    // Show the subject the squash WOULD get. The whole point of issue #17 was that a wrong subject
    // is silent — nothing fails, CI is green, and it is only visible once it is in a published tag.
    // A dry run is the last moment it can be caught, so it must be on screen there.
    print('  Squash subject: ' + (opts.message
      ? `${opts.message} [--message]`
      : buildSquashMessage(repoAbs, target, sess.branch, sess.issues).split('\n')[0]));
    return preOk ? 0 : 1;
  }
  if (!preOk) { process.stderr.write('✗ Aborting: one or more preconditions failed (see ✗ above). Nothing was pushed.\n'); return 1; }

  // ---- (c) B0: merge the TARGET into the branch (in the worktree, or an ephemeral one) ----
  const generated = [...DEFAULT_GENERATED, ...(Array.isArray(doc.generated) ? doc.generated.map(String) : [])];
  const hasPreShip = fs.existsSync(path.join(repoAbs, '.colab', 'hooks', 'pre-ship'));
  let branchDir = sess.wtPath && fs.existsSync(sess.wtPath) ? sess.wtPath : null;
  let ephemeral = false;
  if (!branchDir) {
    branchDir = fs.mkdtempSync(path.join(os.tmpdir(), 'colab-ship-'));
    const add = git.git(['worktree', 'add', branchDir, sess.branch], repoAbs);
    if (!add.ok) { try { fs.rmdirSync(branchDir); } catch (_) {} throw new UserError(`could not check out ${sess.branch} for B0: ${add.stderr.split('\n')[0]}`); }
    ephemeral = true;
  }
  const cleanupEphemeral = () => { if (ephemeral) git.git(['worktree', 'remove', '--force', branchDir], repoAbs); };

  print(`B0: syncing ${target} into the branch …`);
  git.git(['fetch', 'origin', target], branchDir);
  let mergeRef = `origin/${target}`;
  if (!git.git(['rev-parse', '--verify', '--quiet', mergeRef], branchDir).ok) mergeRef = target;
  const merge = git.git(['merge', '--no-edit', mergeRef], branchDir);
  if (!merge.ok) {
    const uf = git.git(['diff', '--name-only', '--diff-filter=U'], branchDir).stdout.split('\n').filter(Boolean);
    const nonGen = uf.filter((f) => !isGeneratedPath(f, generated));
    if (nonGen.length) {
      git.git(['merge', '--abort'], branchDir); cleanupEphemeral();
      process.stderr.write(`✗ B0: merge conflicts in NON-generated files — hand-merge needed, human Phase B:\n  ${nonGen.join('\n  ')}\n`);
      return 1;
    }
    if (hasPreShip) {
      const hk = runHook(repoAbs, 'pre-ship', { wtPath: branchDir, name: sess.name || sess.branch, branch: sess.branch, ports: [], trunk, base: target, issues: sess.issues });
      const committed = hk.ran && hk.ok && git.git(['commit', '--no-edit'], branchDir).ok;
      if (!committed) {
        git.git(['merge', '--abort'], branchDir); cleanupEphemeral();
        process.stderr.write('✗ B0: generated-file conflicts and pre-ship hook could not resolve them. Nothing pushed.\n');
        return 1;
      }
      print(`  generated-file conflicts resolved by .colab/hooks/pre-ship (${uf.join(', ')})`);
    } else {
      git.git(['merge', '--abort'], branchDir); cleanupEphemeral();
      process.stderr.write(`✗ B0: generated-file conflicts and no .colab/hooks/pre-ship to regenerate:\n  ${uf.join('\n  ')}\n`);
      return 1;
    }
  } else {
    print(`  branch is in sync with ${target}.`);
  }

  // ---- (d) B1: re-verify CI, then squash-merge into the target ----
  if (gh) {
    let run2 = git.ghRunLatest(repoAbs, target);
    // Same fallback as the precondition: an ungated line borrows trunk's verdict rather than
    // blocking. The two must agree, or a ship passes the table and dies at the re-check.
    if (run2 && run2.status === 'none' && target !== trunk) run2 = git.ghRunLatest(repoAbs, trunk);
    if (!(run2 && run2.status === 'completed' && run2.conclusion === 'success')) {
      cleanupEphemeral();
      process.stderr.write(`✗ B1: CI for ${target} is no longer green — aborting before merge. Nothing pushed.\n`);
      return 1;
    }
  }
  // WHERE the squash happens. Into trunk it is the main checkout, which is on trunk by invariant
  // (and was just verified to be). Into a declared line it must NOT be: checking the main checkout
  // out onto a long-lived line is the very state that made this axis necessary — everything reading
  // that working tree would serve the line, and a merge is not a reason to break the invariant for
  // even a moment. So the line is merged in an ephemeral worktree that nothing else reads.
  let targetDir = repoAbs;
  let ephemeralTarget = false;
  if (target !== trunk) {
    targetDir = fs.mkdtempSync(path.join(os.tmpdir(), 'colab-ship-target-'));
    const addT = git.git(['worktree', 'add', targetDir, target], repoAbs);
    if (!addT.ok) {
      cleanupEphemeral();
      try { fs.rmdirSync(targetDir); } catch (_) {}
      process.stderr.write(`✗ B1: could not check out "${target}" to merge into: ${addT.stderr.split('\n')[0]}. Nothing pushed.\n`);
      return 1;
    }
    ephemeralTarget = true;
  }
  const cleanupTarget = () => { if (ephemeralTarget) git.git(['worktree', 'remove', '--force', targetDir], repoAbs); };

  let commitMsg;
  if (opts.message) {
    // --message overrides the subject/body, but Closes is spliced in as its own paragraph — never
    // concatenated. Appending it welded ` — Closes #N` onto whatever the message ended with, which
    // for any message carrying a trailer block corrupted the last trailer's value.
    commitMsg = squash.spliceCloses(opts.message, sess.issues);
  } else {
    // Preserve the branch's crafted commit (subject + footers); insert Closes above the footers.
    commitMsg = buildSquashMessage(repoAbs, target, sess.branch, sess.issues);
  }

  print(`B1: squash-merging ${sess.branch} → ${target} …`);
  const sq = git.git(['merge', '--squash', sess.branch], targetDir);
  if (!sq.ok) {
    git.git(['merge', '--abort'], targetDir); cleanupEphemeral(); cleanupTarget();
    process.stderr.write(`✗ B1: squash-merge failed: ${sq.stderr.split('\n')[0]}. Nothing pushed.\n`);
    return 1;
  }
  const commit = git.run('git', ['commit', '-m', commitMsg], { cwd: targetDir });
  if (!commit.ok) {
    git.git(['reset', '--hard', `origin/${target}`], targetDir); cleanupEphemeral(); cleanupTarget();
    // if there was genuinely nothing to commit, say so plainly
    process.stderr.write(`✗ B1: commit failed (${commit.stderr.split('\n')[0] || 'nothing to commit?'}). ${target} reset, nothing pushed.\n`);
    return 1;
  }
  const sha = git.git(['rev-parse', '--short', 'HEAD'], targetDir).stdout;
  print(`  committed ${sha}: ${commitMsg}`);

  // B1 has landed the squash on the target → the worktree's branch is now merged. Record it before B3,
  // so a --keep-worktree entry survives with status=merged (and doctor treats it as a sweep candidate).
  if (sess.name) state.mutate((st) => { if (st.worktrees[sess.name]) st.worktrees[sess.name].status = 'merged'; });

  // ---- (e) B2: push the target with COLAB_SHIP=1 (the sanctioned-path signal for pre-push-guard) ----
  print(`B2: pushing ${target} …`);
  const push = git.run('git', ['push', 'origin', target], { cwd: targetDir, env: { ...process.env, COLAB_SHIP: '1' } });
  if (!push.ok) {
    process.stderr.write(`✗ B2: push failed: ${push.stderr.split('\n')[0]}. ${target} committed locally at ${sha} but NOT pushed — resolve and push by hand (COLAB_HUMAN=1).\n`);
    cleanupEphemeral(); cleanupTarget();
    return 1;
  }
  print('  pushed.');
  cleanupEphemeral();
  cleanupTarget();

  // ---- (f) B3: teardown the worktree (releases claims + ports + ✅ comments) ----
  const worktreeKept = !!(sess.name && opts.keepWorktree);
  if (sess.name && !opts.keepWorktree) {
    print(`B3: removing worktree ${sess.name} …`);
    try { cmdWorktreeRm([sess.name, '--repo', repoAbs, '--force']); }
    catch (e) { warn(`worktree rm reported: ${e.message}`); }
  } else if (sess.name) {
    print(`B3: keeping worktree ${sess.name} (--keep-worktree)`);
  }

  // B3 (cont.) — the shipped branch. Kept by default; --delete-branch opts in. MUST come after the
  // worktree removal above: git refuses to delete a branch checked out in a worktree.
  handleShippedBranch(repoAbs, target, sess.branch, { deleteBranch: opts.deleteBranch, worktreeKept, integration });

  // ---- (g/h) B4 verify auto-close + post 🚢 summary per issue ----
  if (gh) {
    for (const num of sess.issues) {
      const info = git.ghIssueView(repoAbs, num, ['state']);
      if (info && info.state !== 'CLOSED') warn(`#${num} did not auto-close (state=${info.state}) — the Closes trailer needs a push to the DEFAULT branch; close it by hand if ${target} isn't default`);
      const shipSess = sessionCommentSuffix(sess.session, sess.sessionName); // markdown link when both present
      // Name the branch it actually landed on. An issue whose code is on a long-lived line is NOT
      // in trunk, and a comment saying otherwise would be read as "this is in the next release".
      const onLine = target === trunk ? '' : ` (a declared integration line — NOT yet in ${trunk})`;
      const r = git.ghIssueComment(repoAbs, num, `🚢 Shipped to ${target} by colab ship — ${sha}${onLine}${shipSess}`);
      if (!r.ok) warn(`could not post ship comment on #${num}`);
    }
  }

  print('');
  print(`✓ Shipped ${sess.branch} → ${target} @ ${sha}${sess.issues.length ? ' (' + sess.issues.map((n) => '#' + n).join(' ') + ')' : ''}`);
  if (target !== trunk) print(`  "${target}" is a declared line: this work is NOT in ${trunk} until a human merges the line.`);
  return 0;
}

// ---------------------------------------------------------------------------
// landed — "has this branch's work landed on its base?", the one shared answer.
//
// code-sweep sorts candidates into wrap / teardown-only / claim-only / blocked, and code-wrap
// Phase B decides the same thing for one branch. Both used to decide it by prose and judgement,
// and the obvious rule (count the commits ahead) misreports every squash-merge — see lib/landed.js
// for the measurement and for exactly what the rule does and does not cover.
//
// It reads; it never acts. Teardown stays a separate, deliberate command, because a rule that both
// decides and deletes is one bug away from deleting on an `unknown`.
// ---------------------------------------------------------------------------

const HELP_LANDED = `colab landed [--repo <path>] [--worktree <name> | --branch <br>] [--base <br>] [--all] [--json]

Has this branch's work already landed on its base? The shared answer behind code-sweep's buckets
and code-wrap Phase B, so the two stop deciding it by eye.

  landed    the base already contains this content — teardown, do NOT re-merge
  cargo     genuine unmerged work — a full wrap
  unknown   no confident answer — treat as cargo and look by hand (never torn down)

The base is the branch's RECORDED base (\`colab worktree new --base\`), else the repo's trunk from
.github/project.yml. It is never defaulted to "main". --base overrides for an ad-hoc question.

Why "commits ahead" is not the rule: a squash-merge mints a new sha, so a shipped branch's own
commits are never ancestors of the base and a count-only test calls every branch we have ever
shipped unfinished. The mirror rule (diff only) fails when the base moved on underneath. Both
failures were measured on real worktrees. So the answer comes from content — does merging this
branch change the base's tree at all — which stays correct across squashes and later base movement.

LIMIT, stated rather than rounded up: if the base has REWRITTEN the branch's work, the merge
conflicts and no content answer exists. That reports \`unknown\`, never \`landed\`.

  --worktree <name>   ask about a worktree's branch, using its recorded base
  --branch <br>       ask about a branch by name
  --all               every worktree of this repo, as a table
  --base <br>         compare against this ref instead
  --json              machine-readable
No network: fetch first if the base ref may be stale.
`;

/** Trunk for `landed` — project.yml, then the LOCAL origin/HEAD ref. Never "main", never network. */
function landedBaseTrunk(repoAbs) {
  const doc = projectDoc(repoAbs);
  if (doc && doc.trunk) return String(doc.trunk);
  const head = git.git(['symbolic-ref', '--short', 'refs/remotes/origin/HEAD'], repoAbs);
  if (head.ok && head.stdout) return head.stdout.replace(/^origin\//, '');
  throw new UserError(
    'Could not determine the base: no .github/project.yml `trunk:` and no local origin/HEAD. ' +
    'Pass --base <branch>. (It is never assumed to be "main" — guessing the base is how a branch ' +
    'gets measured against the wrong one.)');
}

function cmdLanded(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo', '--worktree': 'worktree', '--branch': 'branch', '--base': 'base' },
    flags: { '--all': 'all', '--json': 'json', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_LANDED);
  const repoAbs = resolveRepo(opts);
  if (!git.repoRoot(repoAbs)) throw new UserError(`${repoAbs} is not a git repo`);
  const st = state.loadState();
  const trunk = opts.base ? String(opts.base) : landedBaseTrunk(repoAbs);

  const ask = (branch, wtName) => {
    const base = opts.base ? String(opts.base) : resolveBase(st, repoAbs, wtName, trunk);
    return { worktree: wtName || null, ...landed.landedState(repoAbs, base, branch) };
  };

  let rows;
  if (opts.all) {
    rows = Object.values(st.worktrees)
      .filter((w) => w.repo === repoAbs)
      .map((w) => ask(w.branch, w.name));
    if (!rows.length) { print('No worktrees for this repo.'); return 0; }
  } else if (opts.worktree) {
    const wt = st.worktrees[opts.worktree];
    if (!wt) throw new UserError(`No worktree "${opts.worktree}" in state`);
    rows = [ask(wt.branch, wt.name)];
  } else if (opts.branch) {
    const wt = Object.values(st.worktrees).find((w) => w.repo === repoAbs && w.branch === opts.branch);
    rows = [ask(opts.branch, wt ? wt.name : null)];
  } else {
    throw new UserError('landed needs --worktree <name>, --branch <br>, or --all');
  }

  if (opts.json) { print(JSON.stringify(rows, null, 2)); return 0; }
  print(table(
    rows.map((r) => [r.branch, r.base, r.state, `${r.commitsAhead === null ? '?' : r.commitsAhead} ahead`, r.method, r.why]),
    ['BRANCH', 'BASE', 'VERDICT', 'COMMITS', 'BY', 'WHY'],
  ));
  // Exit code carries the answer for one branch, so a script can branch on it without parsing:
  // 0 = landed, 1 = cargo or unknown (i.e. "do not tear this down"). --all is informational only.
  if (opts.all) return 0;
  return landed.hasCargo(rows[0]) ? 1 : 0;
}

// ---------------------------------------------------------------------------
// promote — the checked door for PROMOTION (trunk → main), distinct from RELEASE (the tag).
//
// The ladder is: ship (branch → trunk) · promote (trunk → main) · release (tag, always human).
// Promotion permission is split from release permission on purpose: advancing main can be a heavy
// CI verification step (deploy: tag) that the main-loop may do unattended, OR a production deploy
// (deploy: push-main) that always needs a human. `promote` NEVER tags and NEVER deploys directly.
// ---------------------------------------------------------------------------

const HELP_PROMOTE = `colab promote [--repo <path>] [--message "<msg>"] [--dry]

Promote the trunk into main (a --no-ff merge). The SECOND rung after \`ship\`: ship lands work on
trunk; promote advances main. It NEVER tags and NEVER deploys directly — RELEASE (the tag) stays a
human step. There is no --tag/--release flag; promote only ever merges trunk→main and pushes main.

Two gates, both must pass:
  • HARD SAFETY (from the repo's deploy semantics — no field or flag can lower it):
      deploy: push-main → promoting IS a production deploy → requires COLAB_HUMAN=1
      deploy: manual    → promoting is the human's "about to deploy" step → requires COLAB_HUMAN=1
      deploy: tag       → promotion is verification-only (heavy CI on main, no deploy)
      anything else / absent → treated as production-risk → requires COLAB_HUMAN=1 (fail-closed)
  • promotion field (project.yml \`promotion: human | main-loop\`, default human, fail-closed):
      on a deploy:tag repo, \`promotion: main-loop\` lets the main-loop promote with no human word;
      otherwise a human (COLAB_HUMAN=1) is required.
  Tier B (trunk == main) has NO promotion — ship goes straight to main; promote refuses.
  Tier C (deploy: push-main) promotes like A, but the promotion IS the deploy — always human.

On a deploy: manual repo a SUCCESSFUL promote leaves production untouched — main moves, nothing
deploys, and no workflow will fire. The command prints the repo's runbook: as the required next
step, because finishing it does not finish the job.

Preconditions (✓/✗): trunk CI green · trunk == origin/trunk · main == origin/main · main checkout usable.

Options:
  --repo <path>     repo root (default: git root of cwd)
  --message "<msg>" full override of the merge commit message (default: the release: line)
  --dry             print the precondition table + plan; change nothing
`;

// The post-promotion notice for `deploy: manual`, as an array of lines (pure — testable).
//
// On `tag` and `push-main` repos something downstream still runs: the tag deploys later, or
// the push just deployed. `manual` is the ONE case where a SUCCESSFUL command leaves the job
// unfinished — main moved, production did not, and nothing else will ever fire. Said quietly,
// that produces the exact failure this rung exists to prevent: a promoted main everyone reads
// as "shipped" while users are still on the old code. So it gets a block, not a line, and it
// names the runbook the operator has to go run.
function manualDeployBlock(runbookRaw, mainName) {
  const runbook = runbookRaw ? String(runbookRaw).trim() : '';
  const L = [
    '',
    '  ┌─────────────────────────────────────────────────────────────────',
    '  │ PRODUCTION IS NOT UPDATED — deploy: manual',
    '  │',
    `  │ ${mainName} now matches what you are ABOUT to put on the host.`,
    '  │ Nothing has reached production. No workflow will fire. Until a',
    `  │ human runs the deploy, ${mainName} is AHEAD of what users run.`,
    '  │',
  ];
  if (runbook) {
    L.push('  │ NEXT STEP — run this runbook by hand:', `  │     ${runbook}`);
  } else {
    // Never print an empty path: a blank line here would read as "no step required",
    // which is the one thing that must not happen on this branch.
    L.push(
      '  │ NEXT STEP — UNKNOWN: project.yml declares no runbook:.',
      '  │     The hand-deploy is not written down, so this command cannot',
      '  │     tell you what to run. Add runbook: <path> (the audit flags',
      '  │     its absence) and commit the procedure.',
    );
  }
  L.push(
    '  │',
    '  │ Then tag what you deployed — nothing fires from it, but it is',
    '  │ the record of what is on the host.',
    '  └─────────────────────────────────────────────────────────────────',
  );
  return L;
}

function cmdPromote(argv) {
  const opts = parseArgs(argv, {
    values: { '--repo': 'repo', '--message': 'message' },
    flags: { '--dry': 'dry', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_PROMOTE);
  const repoAbs = resolveRepo(opts);
  if (!git.repoRoot(repoAbs)) throw new UserError(`${repoAbs} is not a git repo`);
  const doc = projectDoc(repoAbs);
  const trunk = resolveTrunk(repoAbs, doc);
  if (!trunk) throw new UserError('Could not determine trunk branch (set project.yml trunk:)');
  const MAIN = 'main';

  // Tier B: trunk IS main → there is no promotion to run.
  if (trunk === MAIN) {
    process.stderr.write(`✗ ${shortRepo(repoAbs)}: trunk is "main" (Tier B) — no promotion exists on this repo. Ship goes straight to main.\n`);
    return 1;
  }

  const deploy = doc.deploy ? String(doc.deploy) : '';
  const promotion = doc.promotion === 'main-loop' ? 'main-loop' : 'human'; // fail-closed on unknown
  const human = process.env.COLAB_HUMAN === '1';
  const deployIsTag = deploy === 'tag';

  // ---- GATE (returns before any table, like ship's autonomy gate) ----
  if (deployIsTag) {
    // verification-only promotion: main-loop may run it, else a human must.
    if (promotion !== 'main-loop' && !human) {
      process.stderr.write(`✗ ${shortRepo(repoAbs)}: promotion=${doc.promotion ? promotion : 'human (default)'} — a human must promote ${trunk}→main.\n`);
      process.stderr.write('  Re-run with COLAB_HUMAN=1, or set project.yml promotion: main-loop (deploy is by tag, so promotion is verification-only).\n');
      return 1;
    }
  } else {
    // push-main (or unknown/absent) → promoting main is a production deploy → human required, always.
    if (!human) {
      const why = deploy === 'push-main'
        ? `deploy=push-main — promoting ${trunk}→main IS a PRODUCTION DEPLOY`
        : deploy === 'manual'
          ? `deploy=manual — promoting ${trunk}→main is the "about to deploy" step, and the hand-deploy that follows has no gate but the operator`
          : `deploy=${deploy || '(absent)'} — promoting ${trunk}→main may deploy to production (fail-closed)`;
      process.stderr.write(`✗ ${shortRepo(repoAbs)}: ${why}.\n`);
      process.stderr.write('  This requires a human: re-run with COLAB_HUMAN=1. (No field or flag can lower this bar.)\n');
      return 1;
    }
  }

  // ---- PRECONDITIONS (✓/✗) ----
  const gh = isGhUsable(repoAbs);
  const checks = [];
  git.git(['fetch', 'origin', trunk, MAIN], repoAbs); // best-effort: refresh both refs before comparing

  let ciOk = false;
  if (!gh) checks.push(['✗', 'trunk CI green', 'gh not usable (no auth / no origin) — cannot confirm CI']);
  else {
    const run = git.ghRunLatest(repoAbs, trunk);
    if (!run) checks.push(['✗', 'trunk CI green', 'gh run list failed']);
    else if (run.status === 'completed' && run.conclusion === 'success') { ciOk = true; checks.push(['✓', 'trunk CI green', 'latest run success']); }
    else checks.push(['✗', 'trunk CI green', `latest run status=${run.status} conclusion=${run.conclusion || 'none'} (fail-to-start counts as not green)`]);
  }

  const localTrunk = git.git(['rev-parse', trunk], repoAbs);
  const originTrunk = git.git(['rev-parse', `origin/${trunk}`], repoAbs);
  const trunkSyncOk = localTrunk.ok && originTrunk.ok && localTrunk.stdout === originTrunk.stdout;
  checks.push([trunkSyncOk ? '✓' : '✗', `${trunk} == origin/${trunk}`, trunkSyncOk ? 'in sync' : 'local trunk differs from origin (push/pull first)']);

  const localMain = git.git(['rev-parse', MAIN], repoAbs);
  const originMain = git.git(['rev-parse', `origin/${MAIN}`], repoAbs);
  const mainSyncOk = localMain.ok && originMain.ok && localMain.stdout === originMain.stdout;
  checks.push([mainSyncOk ? '✓' : '✗', `${MAIN} == origin/${MAIN}`,
    !localMain.ok ? 'no local main branch (create it tracking origin/main)' : (mainSyncOk ? 'in sync' : 'local main differs from origin')]);

  // main checkout usable: reuse the repo checkout only if it is ON main and clean; else a temp worktree.
  const headBranch = git.git(['rev-parse', '--abbrev-ref', 'HEAD'], repoAbs).stdout;
  let useRepoDir = false, checkoutOk, checkoutDetail;
  if (headBranch === MAIN) {
    const dirty = git.dirtyTracked(repoAbs);
    checkoutOk = !dirty; useRepoDir = !dirty;
    checkoutDetail = dirty ? 'main checkout has uncommitted tracked changes' : 'on main, clean';
  } else {
    checkoutOk = localMain.ok; // will use a temp worktree; needs a local main ref to check out
    checkoutDetail = localMain.ok ? `checkout on "${headBranch}" — will use a temp worktree for main` : 'no local main to check out';
  }
  checks.push([checkoutOk ? '✓' : '✗', 'main checkout usable', checkoutDetail]);

  const preOk = ciOk && trunkSyncOk && mainSyncOk && checkoutOk;

  // ---- report ----
  print(`promote ${shortRepo(repoAbs)} · ${trunk} → ${MAIN}` + (opts.dry ? '  [DRY RUN]' : ''));
  print(`  deploy: ${deploy || '(absent)'} · promotion: ${promotion}${human ? ' · COLAB_HUMAN=1' : ''}`);
  print('');
  print(table(checks.map((c) => [c[0], c[1], c[2]]), ['', 'PRECONDITION', 'DETAIL']));
  print('');

  const nextRelease = deployIsTag
    ? '  Release is a SEPARATE human step: git tag vX.Y.Z && git push origin vX.Y.Z'
    : deploy === 'manual'
      ? `  Deploy is a SEPARATE human step and this command does NOT perform it: promoting moves main only.\n  Production stays on the old code until a human runs the runbook${doc.runbook ? ` (${doc.runbook})` : ' — and project.yml names none'}.`
      : '  (deploy: push-main — this promotion IS the deploy; there is no separate tag step)';

  if (opts.dry) {
    print(preOk ? '→ READY: preconditions pass. Re-run without --dry to promote.' : '→ NOT READY: fix the ✗ rows above.');
    print(`  Plan: git merge --no-ff ${trunk} into ${MAIN} · push ${MAIN} (COLAB_PROMOTE=1)`);
    print(nextRelease);
    return preOk ? 0 : 1;
  }
  if (!preOk) { process.stderr.write('✗ Aborting: one or more preconditions failed (see ✗ above). Nothing was pushed.\n'); return 1; }

  // ---- ACTION: merge --no-ff trunk → main, push main (never tag, never anything else) ----
  let mainDir = useRepoDir ? repoAbs : null, ephemeral = false;
  if (!mainDir) {
    mainDir = fs.mkdtempSync(path.join(os.tmpdir(), 'colab-promote-'));
    const add = git.git(['worktree', 'add', mainDir, MAIN], repoAbs);
    if (!add.ok) { try { fs.rmdirSync(mainDir); } catch (_) {} throw new UserError(`could not check out main for promotion: ${add.stderr.split('\n')[0]}`); }
    ephemeral = true;
  }
  const cleanup = () => { if (ephemeral) git.git(['worktree', 'remove', '--force', mainDir], repoAbs); };

  const msg = opts.message || `release: ${trunk} → main — ${today()} (promotion via colab promote)`;
  print(`merge --no-ff ${trunk} → ${MAIN} …`);
  const merge = git.run('git', ['merge', '--no-ff', trunk, '-m', msg], { cwd: mainDir });
  if (!merge.ok) {
    git.git(['merge', '--abort'], mainDir); cleanup();
    process.stderr.write(`✗ merge --no-ff failed: ${merge.stderr.split('\n')[0]}. Nothing pushed.\n`);
    return 1;
  }
  const sha = git.git(['rev-parse', '--short', 'HEAD'], mainDir).stdout;

  print(`push ${MAIN} …`);
  const push = git.run('git', ['push', 'origin', MAIN], { cwd: mainDir, env: { ...process.env, COLAB_PROMOTE: '1' } });
  if (!push.ok) {
    cleanup();
    process.stderr.write(`✗ push failed: ${push.stderr.split('\n')[0]}. main merged locally at ${sha} but NOT pushed — resolve and push by hand (COLAB_HUMAN=1).\n`);
    return 1;
  }
  cleanup();

  print('');
  print(`✓ Promoted ${trunk} → ${MAIN} @ ${sha}`);

  if (deploy === 'manual') {
    manualDeployBlock(doc.runbook, MAIN).forEach(print);
    return 0;
  }

  print(deployIsTag
    ? '  main CI now runs the heavy verification suite (no deploy — deploy is by tag).'
    : '  main push will now DEPLOY to production (deploy: push-main).');
  print(nextRelease);
  return 0;
}

