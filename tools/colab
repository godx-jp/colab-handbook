const HELP_PORT = `colab port <alloc|free> ...   ·   colab ports [--json]

Every dev server on this machine gets a unique port. Reserved ports (a project's trunk
dev server, declared in each repo's .github/project.yml as \`ports: [5220]\`, aggregated
across all repos colab knows) are NEVER allocated to a worktree — even when that trunk
server is currently down.

  colab port alloc [--count N] [--range A-B | --at p1,p2,...] [--worktree <name>] [--claim <issue>] [--label <s>]
      Allocate ports. Owner is one of:
        --worktree <name>  ports attach to that worktree entity (the normal path)
        --claim <issue>    ports attach to a standalone claim
        --label <s>        a manual label for a non-repo service
      Allocation mode:
        --count N          N (default 1) CONSECUTIVE free ports found within the range
        --at p1,p2,...     pin EXACTLY these ports; refuses (exit 1) if any is reserved or already
                           allocated. Mutually exclusive with --count/--range. Use this for exact
                           parity (e.g. --at 47150,47151 for an even/odd pair).
      Range resolution (for --count): --range flag > the repo's project.yml worktreePorts > the
      global default config.portRange (${state.DEFAULT_CONFIG.portRange}).

  colab port free <port>            free one port by number
  colab port free --worktree <name> free all ports owned by a worktree
  colab port free --claim <issue>   free all ports owned by a claim (or its worktree)

  colab ports [--json]              list allocated ports and the reserved set
`;

function loadOwnerRefForPortAlloc(st, opts, repoAbs) {
  if (opts.worktree) {
    if (!st.worktrees[opts.worktree]) throw new UserError(`No worktree "${opts.worktree}" in state (create it first, or use --label)`);
    return { type: 'worktree', ref: opts.worktree };
  }
  if (opts.claim) {
    const num = normIssueNum(opts.claim);
    const found = findClaim(st, num, repoAbs);
    if (!found) throw new UserError(`No claim for #${num} — claim it first`);
    return { type: 'claim', ref: found.key };
  }
  return { type: 'manual', ref: opts.label || 'manual' };
}

function cmdPort(argv) {
  const sub = argv[0];
  const rest = argv.slice(1);
  if (sub === 'alloc') return cmdPortAlloc(rest);
  if (sub === 'free') return cmdPortFree(rest);
  return print(HELP_PORT);
}

/**
 * Resolve the port search window for a worktree/port allocation, in precedence order:
 *   1. an explicit --range flag
 *   2. the repo's .github/project.yml worktreePorts: [lo, hi]  (worktrees of THIS repo)
 *   3. the global config.portRange
 */
function resolveWorktreeRange(opts, config, repoAbs) {
  if (opts.range) return opts.range;
  if (repoAbs) {
    const w = ports.repoWorktreePorts(repoAbs);
    if (w) return `${w[0]}-${w[1]}`;
  }
  return config.portRange;
}

/** Parse `--at p1,p2,...` into a sorted, de-duplicated int array, or null if not given. */
function parseAtPorts(opts) {
  if (!opts.at) return null;
  const list = String(opts.at).split(',').map((s) => {
    const n = parseInt(s.trim(), 10);
    if (!Number.isInteger(n) || n <= 0) throw new UserError(`Bad --at port "${s.trim()}" (expected a positive integer)`);
    return n;
  });
  return [...new Set(list)].sort((a, b) => a - b);
}

function cmdPortAlloc(argv) {
  const opts = parseArgs(argv, {
    values: { '--count': 'count', '--range': 'range', '--at': 'at', '--worktree': 'worktree', '--claim': 'claim', '--label': 'label', '--repo': 'repo' },
    flags: { '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_PORT);
  if (opts.at && (opts.count || opts.range)) throw new UserError('--at pins exact ports — it cannot be combined with --count / --range');
  const config = state.loadConfig();
  const count = opts.count ? parseInt(opts.count, 10) : 1;
  if (!Number.isInteger(count) || count < 1) throw new UserError('--count must be a positive integer');
  const explicitRepo = opts.repo ? resolveRepo(opts) : (git.repoRoot(process.cwd()) || null);
  const atPorts = parseAtPorts(opts);

  // For range resolution, a --worktree owner's repo wins over cwd (its project.yml window applies).
  let repoForRange = explicitRepo;
  if (!opts.repo && opts.worktree) {
    const wt = state.loadState().worktrees[opts.worktree];
    if (wt && wt.repo) repoForRange = wt.repo;
  }
  const range = resolveWorktreeRange(opts, config, repoForRange);

  const chosen = state.mutate((st) => {
    const reserved = ports.reservedSet(config, knownRepos(config));
    let found;
    if (atPorts) {
      const conflicts = ports.checkExact(atPorts, st, reserved);
      if (conflicts.length) {
        throw new UserError(`Cannot pin ${conflicts.map((c) => `${c.port} (${c.reason})`).join(', ')} — pick free ports`);
      }
      found = atPorts;
    } else {
      found = ports.findConsecutive(count, range, st, reserved);
      if (!found) throw new UserError(`Could not find ${count} consecutive free port(s) in ${range}`);
    }
    const owner = loadOwnerRefForPortAlloc(st, opts, explicitRepo);
    for (const p of found) {
      st.ports[String(p)] = { port: p, owner, host: HOST, created: nowISO() };
    }
    if (owner.type === 'worktree') {
      const wt = st.worktrees[owner.ref];
      wt.ports = Array.from(new Set([...wt.ports, ...found])).sort((a, b) => a - b);
    }
    return { found, owner };
  });

  // A listening port pinned via --at is allowed but worth surfacing.
  if (atPorts) for (const p of atPorts) if (ports.isListening(p)) warn(`port ${p} is currently LISTENing — pinned anyway (--at)`);
  print(`Allocated ${chosen.found.join(', ')} → ${chosen.owner.type}:${chosen.owner.ref}${atPorts ? ' (pinned)' : ''}`);
  return 0;
}

function cmdPortFree(argv) {
  const opts = parseArgs(argv, {
    values: { '--worktree': 'worktree', '--claim': 'claim', '--repo': 'repo' },
    flags: { '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_PORT);
  const repoAbs = opts.repo ? resolveRepo(opts) : (git.repoRoot(process.cwd()) || null);

  const freed = state.mutate((st) => {
    let targets = [];
    if (opts.worktree) {
      targets = Object.keys(st.ports).filter((p) => st.ports[p].owner.type === 'worktree' && st.ports[p].owner.ref === opts.worktree);
    } else if (opts.claim) {
      const num = normIssueNum(opts.claim);
      const found = findClaim(st, num, repoAbs);
      if (!found) throw new UserError(`No claim for #${num}`);
      const wt = found.claim.worktree;
      targets = Object.keys(st.ports).filter((p) => {
        const o = st.ports[p].owner;
        return (o.type === 'claim' && o.ref === found.key) || (wt && o.type === 'worktree' && o.ref === wt);
      });
    } else if (opts._[0]) {
      const p = String(parseInt(opts._[0], 10));
      if (!st.ports[p]) throw new UserError(`Port ${p} is not allocated in state`);
      targets = [p];
    } else {
      throw new UserError('port free needs a <port>, --worktree <name>, or --claim <issue>');
    }
    for (const p of targets) {
      const o = st.ports[p].owner;
      if (o.type === 'worktree' && st.worktrees[o.ref]) {
        st.worktrees[o.ref].ports = st.worktrees[o.ref].ports.filter((x) => x !== Number(p));
      }
      delete st.ports[p];
    }
    return targets;
  });

  if (freed.length === 0) print('No matching allocated ports.');
  else print(`Freed ${freed.join(', ')}`);
  return 0;
}

function cmdPorts(argv) {
  const opts = parseArgs(argv, { flags: { '--json': 'json', '-h': 'help', '--help': 'help' } });
  if (opts.help) return print(HELP_PORT);
  const config = state.loadConfig();
  const st = state.loadState();
  const reserved = ports.reservedSet(config, knownRepos(config));
  if (opts.json) {
    print(JSON.stringify({ allocated: st.ports, reserved: Object.fromEntries(reserved) }, null, 2));
    return 0;
  }
  const allocRows = Object.values(st.ports).sort((a, b) => a.port - b.port)
    .map((p) => [p.port, `${p.owner.type}:${p.owner.ref}`, p.host, p.created.slice(0, 10)]);
  print('Allocated ports:');
  print(allocRows.length ? table(allocRows, ['PORT', 'OWNER', 'HOST', 'SINCE']) : '  (none)');
  print('\nReserved (trunk dev servers — never allocated):');
  const resRows = [...reserved.entries()].sort((a, b) => a[0] - b[0]).map(([p, src]) => [p, src]);
  print(resRows.length ? table(resRows, ['PORT', 'SOURCE']) : '  (none — no repos configured / no project.yml ports)');
  return 0;
}

