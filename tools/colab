const HELP_ROOT = `colab — coordinate parallel coding sessions/agents on one machine.

Three independent capabilities (each works standalone):
  ISSUE CLAIMS   so parallel sessions don't grab the same issue (local + GitHub)
  PORTS          a unique dev-server port per session, never colliding with a trunk port
  WORKTREES      OPTIONAL git worktrees; machine-specific setup via repo hooks

Commands:
  claim <issue> [<issue>...] [--worktree N] [--branch B] [--repo P]   claim issue(s)
  release <issue> [--repo P]                                          release one issue
  claims [--json] [--sync]                                            list / reconcile with GitHub

  port alloc [--count N] [--range A-B] [--worktree N|--claim I|--label S]
  port free <port> | --worktree N | --claim I
  ports [--json]                                                      list ports + reserved set

  worktree new <branch> [--issues N,M,K] [--ports N] [--name X] [--trunk T] [--repo P]
  worktree rm <name> [--force] [--repo P]
  worktrees [--json]

  doctor [--prune] [--ttl H] [--json]   heal dead worktrees / orphan + stale claims / orphan ports
  release-notes [<range>] [--repo P] [--out F] [--headline "..."]   grouped Markdown release summary
  template [<name>] [--dest F] [--repo P] [--force]   copy a handbook workflow template, stamped
  register [<path>] [--remove] [--list]   add a repo to BOTH fleet registries (repos.txt + config.json)
  config [show|add-repo P|rm-repo P|set K V]

State is machine-local at ~/.colab/ (override with COLAB_HOME). Run any command with
--help for details. Exit code is 0 on success, non-zero on failure.
`;

function print(s) { process.stdout.write(s.endsWith('\n') ? s : s + '\n'); return 0; }
function warn(s) { process.stderr.write(`! ${s}\n`); }

function main(argv) {
  const cmd = argv[0];
  const rest = argv.slice(1);
  switch (cmd) {
    case 'claim': return cmdClaim(rest);
    case 'release': return cmdRelease(rest);
    case 'claims': return cmdClaims(rest);
    case 'port': return cmdPort(rest);
    case 'ports': return cmdPorts(rest);
    case 'worktree': return cmdWorktree(rest);
    case 'worktrees': return cmdWorktrees(rest);
    case 'doctor': return cmdDoctor(rest);
    case 'release-notes': return cmdReleaseNotes(rest);
    case 'template': return cmdTemplate(rest);
    case 'register': return cmdRegister(rest);
    case 'config': return cmdConfig(rest);
    case undefined:
    case '-h': case '--help': case 'help': return print(HELP_ROOT);
    case '--version': case 'version': return print('colab 1.0.0');
    default:
      warn(`Unknown command: ${cmd}`);
      print(HELP_ROOT);
      return 2;
  }
}

try {
  process.exit(main(process.argv.slice(2)) || 0);
} catch (e) {
  if (e instanceof UserError) { process.stderr.write(`✗ ${e.message}\n`); process.exit(1); }
  process.stderr.write(`✗ ${e.stack || e.message}\n`);
  process.exit(1);
}
