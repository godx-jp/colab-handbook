const HELP_DOCTOR = `colab doctor [--prune] [--ttl <hours>] [--json]

Health-check the machine-local state and heal drift.
  - A worktree whose directory no longer exists on disk is DEAD: its claims are pruned
    and its ports freed (--prune actually removes; default only reports).
  - Claims referencing a worktree that isn't in state are orphans (same treatment).
  - Worktree-less claims older than TTL (default 24h, --ttl to change) are REPORTED, not
    auto-removed (they may be deliberate trunk claims). --prune removes them too and frees
    any ports they own.
  - Ports owned by a vanished worktree/claim are freed on --prune.

This exists because claims made without a worktree were never auto-healed before, and a
real repo accumulated 17 stale same-day claims. Run \`colab doctor\` regularly; \`--prune\`
in a cleanup cron.

  --prune   apply the fixes (default: report only)
  --ttl N   hours before a worktree-less claim is flagged stale (default 24)
  --json    machine-readable report
`;

function cmdDoctor(argv) {
  const opts = parseArgs(argv, {
    values: { '--ttl': 'ttl' }, flags: { '--prune': 'prune', '--json': 'json', '-h': 'help', '--help': 'help' },
  });
  if (opts.help) return print(HELP_DOCTOR);
  const config = state.loadConfig();
  const ttl = opts.ttl ? parseFloat(opts.ttl) : config.claimTTLHours;

  const report = { deadWorktrees: [], orphanClaims: [], staleClaims: [], orphanPorts: [], prunedPorts: [], pruned: !!opts.prune };

  const apply = (fn) => opts.prune ? state.mutate(fn) : fn(state.loadState());

  apply((st) => {
    // 1. dead worktrees (path gone)
    for (const wt of Object.values(st.worktrees)) {
      const dead = wt.path && !fs.existsSync(wt.path);
      if (!dead) continue;
      const claims = Object.entries(st.claims).filter(([, c]) => c.worktree === wt.name);
      report.deadWorktrees.push({ name: wt.name, repo: shortRepo(wt.repo), path: wt.path, ports: wt.ports, claims: claims.map(([, c]) => c.issue) });
      if (opts.prune) {
        for (const [k] of claims) delete st.claims[k];
        for (const p of wt.ports) { delete st.ports[String(p)]; report.prunedPorts.push(p); }
        delete st.worktrees[wt.name];
      }
    }
    // 2. orphan claims (worktree ref not in state)
    for (const [k, c] of Object.entries(st.claims)) {
      if (c.worktree && !st.worktrees[c.worktree]) {
        report.orphanClaims.push({ issue: c.issue, repo: shortRepo(c.repo), worktree: c.worktree });
        if (opts.prune) delete st.claims[k];
      }
    }
    // 3. stale worktree-less claims (report only; prune if asked)
    for (const [k, c] of Object.entries(st.claims)) {
      if (!c.worktree) {
        const age = hoursSince(c.created);
        if (age > ttl) {
          report.staleClaims.push({ issue: c.issue, repo: shortRepo(c.repo), ageHours: Math.round(age), host: c.host });
          if (opts.prune) {
            // free any ports owned by this claim
            for (const p of Object.keys(st.ports)) {
              if (st.ports[p].owner.type === 'claim' && st.ports[p].owner.ref === k) { delete st.ports[p]; report.prunedPorts.push(Number(p)); }
            }
            delete st.claims[k];
          }
        }
      }
    }
    // 4. orphan ports (owner vanished)
    for (const [p, rec] of Object.entries(st.ports)) {
      const o = rec.owner;
      const orphan = (o.type === 'worktree' && !st.worktrees[o.ref]) || (o.type === 'claim' && !st.claims[o.ref]);
      if (orphan) {
        report.orphanPorts.push({ port: Number(p), owner: `${o.type}:${o.ref}` });
        if (opts.prune) { delete st.ports[p]; report.prunedPorts.push(Number(p)); }
      }
    }
  });

  if (opts.json) { print(JSON.stringify(report, null, 2)); return 0; }

  const verb = opts.prune ? 'Pruned' : 'Found';
  let issues = 0;
  if (report.deadWorktrees.length) {
    issues += report.deadWorktrees.length;
    print(`${verb} ${report.deadWorktrees.length} dead worktree(s) (directory gone):`);
    for (const w of report.deadWorktrees) print(`  ${w.name} [${w.repo}] claims=${w.claims.join(' ') || '-'} ports=${w.ports.join(',') || '-'}`);
  }
  if (report.orphanClaims.length) {
    issues += report.orphanClaims.length;
    print(`${verb} ${report.orphanClaims.length} orphan claim(s) (worktree not in state):`);
    for (const c of report.orphanClaims) print(`  ${c.issue} [${c.repo}] → missing worktree "${c.worktree}"`);
  }
  if (report.staleClaims.length) {
    print(`${opts.prune ? 'Pruned' : 'Flagged'} ${report.staleClaims.length} stale worktree-less claim(s) (> ${ttl}h):`);
    for (const c of report.staleClaims) print(`  ${c.issue} [${c.repo}] age=${c.ageHours}h host=${c.host}`);
    if (!opts.prune) print('  (worktree-less claims are not auto-removed — re-run with --prune to remove)');
  }
  if (report.orphanPorts.length) {
    print(`${verb} ${report.orphanPorts.length} orphan port(s):`);
    for (const p of report.orphanPorts) print(`  ${p.port} owner=${p.owner}`);
  }
  if (opts.prune && report.prunedPorts.length) print(`Freed ports: ${[...new Set(report.prunedPorts)].sort((a, b) => a - b).join(', ')}`);
  if (issues === 0 && report.staleClaims.length === 0 && report.orphanPorts.length === 0) print('All healthy — nothing to prune.');
  return 0;
}

